---
import type { Block, ThemeTokens } from "@astropress/core/types/theme";
import { buildFormHtml } from "../lib/formRenderer";

interface Props {
  blocks: Block[];
  tokens: ThemeTokens;
  formsById?: Record<string, any>;
  navItems?: { url: string; title: string }[];
  siteTitle?: string;
  siteTagline?: string;
  wrapMain?: boolean; // false for FSE templates that own full-width layout
}

const { blocks, tokens, formsById = {}, navItems = [], siteTitle = "", siteTagline = "", wrapMain = true } = Astro.props;

function esc(s: unknown) {
  return String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function renderBlock(block: Block): string {
  const p = block.props;

  switch (block.type) {
    case "hero": {
      const align = String(p.align || "center");
      const height = Number(p.height) || 480;
      const itemsAlign = align === "left" ? "flex-start" : align === "right" ? "flex-end" : "center";
      return `
<section class="ap-block ap-block-hero" style="background:${esc(p.bgColor || "#1a1a2e")};color:${esc(p.textColor || "#fff")};padding:${tokens.spacing.sectionY} 48px;text-align:${align};min-height:${height}px;display:flex;flex-direction:column;align-items:${itemsAlign};justify-content:center;">
  <h1 style="font-family:${tokens.fonts.heading};font-size:clamp(2rem,5vw,3rem);font-weight:700;margin:0 0 16px;line-height:1.15;max-width:800px;">${esc(p.heading)}</h1>
  ${p.subtext ? `<p style="font-size:1.15rem;margin:0 0 32px;opacity:0.85;max-width:560px;">${esc(p.subtext)}</p>` : ""}
  ${p.buttonText ? `<a href="${esc(p.buttonUrl || "#")}" style="display:inline-block;background:${tokens.colors.primary};color:#fff;padding:14px 32px;border-radius:${tokens.spacing.borderRadius};font-weight:600;font-size:1rem;text-decoration:none;">${esc(p.buttonText)}</a>` : ""}
</section>`;
    }

    case "text":
      return `
<section class="ap-block ap-block-text" style="padding:${tokens.spacing.sectionY} 48px;max-width:${tokens.spacing.containerMax};margin:0 auto;text-align:${esc(p.align || "left")};">
  <div style="font-family:${tokens.fonts.body};font-size:1.05rem;line-height:1.75;color:${tokens.colors.text};">
    ${String(p.content || "")}
  </div>
</section>`;

    case "image": {
      const maxW = p.width === "full" ? "100%" : p.width === "wide" ? "900px" : "640px";
      return `
<section class="ap-block ap-block-image" style="padding:32px 48px;text-align:${esc(p.align || "center")};">
  ${p.src ? `<img src="${esc(p.src)}" alt="${esc(p.alt)}" loading="lazy" style="max-width:${maxW};border-radius:${tokens.spacing.borderRadius};display:inline-block;" />` : ""}
  ${p.caption ? `<p style="font-size:0.85rem;color:${tokens.colors.textMuted};margin-top:8px;text-align:center;">${esc(p.caption)}</p>` : ""}
</section>`;
    }

    case "cta":
      return `
<section class="ap-block ap-block-cta" style="background:${esc(p.bgColor || tokens.colors.primary)};color:${esc(p.textColor || "#fff")};padding:${tokens.spacing.sectionY} 48px;text-align:center;">
  <div style="max-width:${tokens.spacing.containerMax};margin:0 auto;">
    <h2 style="font-family:${tokens.fonts.heading};font-size:2rem;font-weight:700;margin:0 0 12px;">${esc(p.heading)}</h2>
    ${p.text ? `<p style="margin:0 0 32px;opacity:0.9;font-size:1.1rem;max-width:560px;margin-left:auto;margin-right:auto;">${esc(p.text)}</p>` : ""}
    ${p.buttonText ? `<a href="${esc(p.buttonUrl || "#")}" style="display:inline-block;background:rgba(255,255,255,0.15);color:inherit;padding:12px 28px;border-radius:${tokens.spacing.borderRadius};border:2px solid rgba(255,255,255,0.4);font-weight:600;text-decoration:none;">${esc(p.buttonText)}</a>` : ""}
  </div>
</section>`;

    case "features": {
      const items = (p.items as any[]) || [];
      const cols = Number(p.cols) || 3;
      const itemsHtml = items.map(item => `
<div style="padding:28px;background:${tokens.colors.surface};border-radius:${tokens.spacing.borderRadius};border:1px solid ${tokens.colors.border};">
  <div style="font-size:2rem;margin-bottom:12px;">${esc(item.icon || "★")}</div>
  <h3 style="font-family:${tokens.fonts.heading};margin:0 0 8px;font-size:1.05rem;">${esc(item.title)}</h3>
  <p style="margin:0;color:${tokens.colors.textMuted};font-size:0.95rem;line-height:1.6;">${esc(item.text)}</p>
</div>`).join("");
      return `
<section class="ap-block ap-block-features" style="padding:${tokens.spacing.sectionY} 48px;text-align:center;">
  <div style="max-width:${tokens.spacing.containerMax};margin:0 auto;">
    ${p.heading ? `<h2 style="font-family:${tokens.fonts.heading};font-size:2rem;font-weight:700;margin:0 0 12px;">${esc(p.heading)}</h2>` : ""}
    ${p.subtext ? `<p style="color:${tokens.colors.textMuted};margin:0 0 48px;font-size:1.05rem;">${esc(p.subtext)}</p>` : ""}
    <div style="display:grid;grid-template-columns:repeat(${cols},1fr);gap:28px;text-align:left;">${itemsHtml}</div>
  </div>
</section>`;
    }

    case "columns":
      return `
<section class="ap-block ap-block-columns" style="padding:${tokens.spacing.sectionY} 48px;">
  <div style="max-width:${tokens.spacing.containerMax};margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:${esc(p.gap || "2rem")};">
    <div style="font-family:${tokens.fonts.body};line-height:1.75;">${String(p.leftContent || "")}</div>
    <div style="font-family:${tokens.fonts.body};line-height:1.75;">${String(p.rightContent || "")}</div>
  </div>
</section>`;

    case "form": {
      const formId = String(p.formId || "");
      const form = formsById[formId];
      if (!form) return `<section class="ap-block ap-block-form" style="padding:32px 48px;"><div style="max-width:560px;margin:0 auto;padding:24px;background:${tokens.colors.surface};border:1px solid ${tokens.colors.border};border-radius:${tokens.spacing.borderRadius};text-align:center;color:${tokens.colors.textMuted};font-size:14px;">Form not found.</div></section>`;
      return `<section class="ap-block ap-block-form" style="padding:${tokens.spacing.sectionY} 48px;"><div style="max-width:560px;margin:0 auto;">${buildFormHtml(form)}</div></section>`;
    }

    case "nav": {
      const align = String(p.align || "right");
      const navLinksHtml = navItems.map(item =>
        `<li><a href="${esc(item.url)}" style="color:${tokens.colors.textMuted};text-decoration:none;font-size:0.9rem;padding:8px 12px;display:block;">${esc(item.title)}</a></li>`
      ).join("");
      return `
<header class="ap-block ap-block-nav" style="background:${tokens.colors.background};border-bottom:1px solid ${tokens.colors.border};padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
  <a href="/" style="font-family:${tokens.fonts.heading};font-weight:700;font-size:1.2rem;color:${tokens.colors.text};text-decoration:none;">${p.logoText ? esc(p.logoText) : esc(siteTitle)}</a>
  ${navItems.length > 0 ? `<nav><ul style="display:flex;gap:0;list-style:none;margin:0;padding:0;">${navLinksHtml}</ul></nav>` : ""}
</header>`;
    }

    case "site-title":
      return `
<div class="ap-block ap-block-site-title" style="padding:24px 48px;text-align:${esc(p.align || "left")};">
  <a href="/" style="font-family:${tokens.fonts.heading};font-weight:700;font-size:${p.size === "large" ? "2rem" : p.size === "small" ? "1rem" : "1.4rem"};color:${tokens.colors.text};text-decoration:none;">${esc(siteTitle)}</a>
  ${p.showTagline && siteTagline ? `<div style="color:${tokens.colors.textMuted};font-size:0.9rem;margin-top:4px;">${esc(siteTagline)}</div>` : ""}
</div>`;

    case "spacer":
      return `<div class="ap-block ap-block-spacer" style="height:${Number(p.height) || 64}px;"></div>`;

    case "divider":
      return `<div class="ap-block ap-block-divider" style="padding:0 48px;"><hr style="border:none;border-top:${Number(p.thickness) || 1}px ${esc(p.style || "solid")} ${esc(p.color || tokens.colors.border)};margin:0;" /></div>`;

    case "html":
      return `<div class="ap-block ap-block-html">${String(p.content || "")}</div>`;

    case "ai":
      return ""; // AI placeholder — not rendered on frontend

    default:
      return "";
  }
}

const html = blocks.map(renderBlock).join("\n");
---
<div class="ap-blocks" set:html={html} />
