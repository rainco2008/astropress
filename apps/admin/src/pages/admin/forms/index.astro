---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { wpOptions } from "@astropress/core/schema";
import { eq } from "drizzle-orm";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

let forms: any[] = [];
try {
  const [row] = await db.select({ value: wpOptions.optionValue }).from(wpOptions)
    .where(eq(wpOptions.optionName, "astropress_forms")).limit(1);
  forms = row?.value ? JSON.parse(row.value) : [];
} catch {}

forms.sort((a: any, b: any) => (b.updatedAt ?? "").localeCompare(a.updatedAt ?? ""));

function fieldCount(form: any) {
  return (form.fields ?? []).filter((f: any) =>
    !["page_break", "section_divider", "html"].includes(f.type)
  ).length;
}
---
<AdminLayout title="Forms">

  <h1 class="wp-heading-inline">Forms</h1>
  <a href="/admin/forms/create" class="page-title-action">Add New</a>
  <hr class="wp-header-end" />

  {forms.length === 0 ? (
    <div class="ap-empty-state">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="color:#8c8f94;margin-bottom:12px">
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
        <rect x="8" y="2" width="8" height="4" rx="1"/>
        <line x1="9" y1="12" x2="15" y2="12"/>
        <line x1="9" y1="16" x2="13" y2="16"/>
      </svg>
      <p style="font-size:14px;color:#646970;margin:0 0 16px">No forms yet. Create one to start collecting entries.</p>
      <a href="/admin/forms/create" class="button button-primary">Create Your First Form</a>
    </div>
  ) : (
    <table class="wp-list-table widefat fixed striped">
      <thead>
        <tr>
          <th scope="col" class="manage-column column-primary" style="width:35%">Name</th>
          <th scope="col" class="manage-column" style="width:8%">Fields</th>
          <th scope="col" class="manage-column" style="width:28%">Shortcode</th>
          <th scope="col" class="manage-column" style="width:14%">Last Modified</th>
          <th scope="col" class="manage-column" style="width:15%">Entries</th>
        </tr>
      </thead>
      <tbody>
        {forms.map((form: any) => (
          <tr>
            <td class="title column-title has-row-actions column-primary">
              <strong>
                <a href={`/admin/forms/${form.id}`} class="row-title">
                  {form.title ?? form.name ?? "Untitled Form"}
                </a>
              </strong>
              <div class="row-actions">
                <span class="edit">
                  <a href={`/admin/forms/${form.id}`}>Edit</a> |
                </span>
                <span class="view">
                  <a href={`/admin/forms/${form.id}/entries`}>Entries</a> |
                </span>
                <span class="view">
                  <a href={`/forms/${form.id}`} target="_blank" rel="noopener">Preview</a> |
                </span>
                <span class="trash">
                  <button
                    onclick={`if(confirm('Delete "${form.title ?? form.name}"? This cannot be undone.')){fetch('/api/forms/${form.id}',{method:'DELETE'}).then(r=>{if(r.ok)location.reload()})}`}
                    class="ap-row-delete-btn"
                  >
                    Delete
                  </button>
                </span>
              </div>
            </td>
            <td>
              <span class="ap-field-count">{fieldCount(form)}</span>
            </td>
            <td>
              <code class="ap-shortcode">[wpforms id="{form.id}"]</code>
            </td>
            <td style="color:var(--wp-gray-600)">
              {form.updatedAt ? new Date(form.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) : "—"}
            </td>
            <td>
              <a href={`/admin/forms/${form.id}/entries`} style="font-size:13px;color:var(--wp-blue);text-decoration:none">
                View entries
              </a>
            </td>
          </tr>
        ))}
      </tbody>

    </table>
  )}

</AdminLayout>

<style is:global>
  /* ── Field count badge ───────────────────────────────────────────────── */
  .ap-field-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    background: #f0f0f1;
    border-radius: 11px;
    font-size: 12px;
    font-weight: 600;
    color: #3c434a;
  }

  /* ── Shortcode ───────────────────────────────────────────────────────── */
  .ap-shortcode {
    font-size: 11px;
    background: #f6f7f7;
    border: 1px solid #dcdcde;
    padding: 2px 6px;
    border-radius: 2px;
    color: #3c434a;
    user-select: all;
    cursor: text;
  }
</style>
