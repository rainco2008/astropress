---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getFieldGroups } from "@astropress/core/registry";

const groups = getFieldGroups();
---
<AdminLayout title="Custom Fields">

  <h1 class="wp-heading-inline">Custom Fields</h1>
  <a href="/admin/custom-fields/new" class="page-title-action">Add New</a>
  <hr class="wp-header-end" />

  {groups.length === 0 ? (
    <div class="ap-empty-state">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="color:#8c8f94;margin-bottom:12px">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      <h2 style="font-size:15px;font-weight:600;color:#1d2327;margin:0 0 8px">No Field Groups Yet</h2>
      <p style="font-size:13px;color:#646970;margin:0 0 20px;line-height:1.5">
        Create field groups to add custom fields to posts, pages, and custom post types.
      </p>
      <a href="/admin/custom-fields/new" class="button button-primary">Add Your First Field Group</a>
    </div>
  ) : (
    <table class="wp-list-table widefat fixed striped">
      <thead>
        <tr>
          <th scope="col" class="manage-column column-primary">Title</th>
          <th scope="col" class="manage-column" style="width:80px">Fields</th>
          <th scope="col" class="manage-column">Location</th>
          <th scope="col" class="manage-column" style="width:90px">Status</th>
        </tr>
      </thead>
      <tbody>
        {groups.map(group => (
          <tr>
            <td class="title column-title has-row-actions column-primary">
              <strong>
                <a href={`/admin/custom-fields/${group.id}`} class="row-title">{group.title}</a>
              </strong>
              <div style="font-size:11px;color:#8c8f94;font-family:monospace;margin-top:2px">{group.key}</div>
              <div class="row-actions">
                <span class="edit"><a href={`/admin/custom-fields/${group.id}`}>Edit</a></span>
              </div>
            </td>
            <td style="color:var(--wp-gray-600)">
              {group.fields.length} {group.fields.length === 1 ? "field" : "fields"}
            </td>
            <td style="color:var(--wp-gray-600);font-size:12px">
              {group.location?.[0]?.[0] ? (
                <code style="font-size:11px;background:#f6f7f7;border:1px solid #dcdcde;padding:1px 5px;border-radius:2px">
                  {group.location[0][0].param} {group.location[0][0].operator} {group.location[0][0].value}
                </code>
              ) : <span style="color:#c3c4c7">—</span>}
            </td>
            <td>
              <span style={`display:inline-block;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:600;background:${group.active ? "#d1e7dd" : "#f0f0f1"};color:${group.active ? "#146c43" : "#646970"}`}>
                {group.active ? "Active" : "Inactive"}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

</AdminLayout>

