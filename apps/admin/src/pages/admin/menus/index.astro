---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { eq } from "drizzle-orm";
import { wpTerms, wpTermTaxonomy } from "@astropress/core/schema";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

const menus = await db
  .select({ id: wpTerms.termId, name: wpTerms.name, slug: wpTerms.slug })
  .from(wpTerms)
  .innerJoin(wpTermTaxonomy, eq(wpTermTaxonomy.termId, wpTerms.termId))
  .where(eq(wpTermTaxonomy.taxonomy, "nav_menu"));
---
<AdminLayout title="Menus">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
    <h1 class="page-title" style="margin:0">Menus</h1>
    <button id="btn-new" style="background:#2271b1;color:#fff;padding:8px 16px;border-radius:4px;font-size:13px;font-weight:600;border:none;cursor:pointer">
      + New Menu
    </button>
  </div>

  <div id="create-panel" style="display:none;background:#fff;border:1px solid #dcdcde;border-radius:8px;padding:20px;margin-bottom:20px">
    <h2 style="margin:0 0 14px;font-size:15px;font-weight:600">Create Menu</h2>
    <div style="display:flex;gap:10px;align-items:flex-end">
      <div style="flex:1">
        <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Menu Name</label>
        <input id="new-name" type="text" placeholder="e.g. Primary Navigation"
          style="width:100%;padding:7px 10px;font-size:13px;border:1px solid #8c8f94;border-radius:3px;box-sizing:border-box" />
      </div>
      <button id="btn-create" style="padding:7px 18px;background:#2271b1;color:#fff;border:none;border-radius:3px;font-size:13px;cursor:pointer">Create</button>
      <button id="btn-cancel" style="padding:7px 14px;background:#f6f7f7;border:1px solid #dcdcde;border-radius:3px;font-size:13px;cursor:pointer">Cancel</button>
    </div>
  </div>

  {menus.length === 0 ? (
    <div style="background:#fff;border:1px solid #dcdcde;border-radius:8px;padding:48px;text-align:center;color:#646970">
      <p style="margin:0 0 16px;font-size:15px">No menus yet.</p>
      <p style="margin:0;font-size:13px">Create a menu and add it to your site's navigation.</p>
    </div>
  ) : (
    <div style="background:#fff;border:1px solid #dcdcde;border-radius:8px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="background:#f6f7f7">
            <th style="text-align:left;padding:10px 16px;font-weight:600;color:#3c434a">Name</th>
            <th style="text-align:left;padding:10px 16px;font-weight:600;color:#3c434a">Slug</th>
            <th style="text-align:left;padding:10px 16px;font-weight:600;color:#3c434a">Location</th>
            <th style="padding:10px 16px"></th>
          </tr>
        </thead>
        <tbody>
          {menus.map((menu) => (
            <tr style="border-top:1px solid #f0f0f1">
              <td style="padding:12px 16px;font-weight:600">{menu.name}</td>
              <td style="padding:12px 16px;color:#646970">
                <code style="font-size:12px;background:#f6f7f7;padding:2px 6px;border-radius:3px">{menu.slug}</code>
              </td>
              <td style="padding:12px 16px;color:#646970;font-size:12px">
                {menu.slug === "primary" ? <span style="color:#2271b1;font-weight:600">Primary Navigation</span> : "—"}
                {menu.slug === "footer" ? <span style="color:#2271b1;font-weight:600">Footer Navigation</span> : ""}
              </td>
              <td style="padding:12px 16px;text-align:right">
                <a href={`/admin/menus/${menu.id}`}
                   style="font-size:12px;color:#2271b1;text-decoration:none;margin-right:12px">Edit</a>
                <button
                  onclick={`deleteMenu(${menu.id}, '${menu.name.replace(/'/g,"\\'")}')` }
                  style="background:none;border:none;color:#dc3232;cursor:pointer;font-size:12px;padding:0">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <div style="margin-top:24px;background:#fff;border:1px solid #dcdcde;border-radius:8px;padding:20px">
    <h2 style="margin:0 0 12px;font-size:14px;font-weight:600;color:#3c434a">Menu Locations</h2>
    <p style="margin:0;font-size:13px;color:#646970">
      The web theme uses the menu with slug <code style="background:#f6f7f7;padding:2px 6px;border-radius:3px">primary</code> as the main navigation.
      Name your menu <strong>Primary</strong> (or any name) — as long as its slug is <code style="background:#f6f7f7;padding:2px 6px;border-radius:3px">primary</code> it will appear in the header automatically.
    </p>
  </div>

  <script>
    document.getElementById('btn-new')!.onclick = () => {
      document.getElementById('create-panel')!.style.display = 'block';
      (document.getElementById('new-name') as HTMLInputElement).focus();
    };
    document.getElementById('btn-cancel')!.onclick = () => {
      document.getElementById('create-panel')!.style.display = 'none';
    };
    document.getElementById('btn-create')!.onclick = async () => {
      const name = (document.getElementById('new-name') as HTMLInputElement).value.trim();
      if (!name) return;
      const r = await fetch('/api/menus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (r.ok) {
        const { id } = await r.json();
        window.location.href = `/admin/menus/${id}`;
      }
    };
    (document.getElementById('new-name') as HTMLInputElement).onkeydown = (e) => {
      if (e.key === 'Enter') (document.getElementById('btn-create') as HTMLButtonElement).click();
    };
    async function deleteMenu(id: number, name: string) {
      if (!confirm(`Delete menu "${name}" and all its items? This cannot be undone.`)) return;
      await fetch(`/api/menus/${id}`, { method: 'DELETE' });
      location.reload();
    }
    (window as any).deleteMenu = deleteMenu;
  </script>
</AdminLayout>
