---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { eq, and } from "drizzle-orm";
import { wpTerms, wpTermTaxonomy, wpTermRelationships, wpPosts, wpPostmeta } from "@astropress/core/schema";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

const menuId = Number(Astro.params.id);
if (!menuId) return Astro.redirect("/admin/menus");

const [menu] = await db
  .select({ id: wpTerms.termId, name: wpTerms.name, slug: wpTerms.slug })
  .from(wpTerms)
  .where(eq(wpTerms.termId, menuId))
  .limit(1);

if (!menu) return Astro.redirect("/admin/menus");

const [tt] = await db
  .select({ id: wpTermTaxonomy.termTaxonomyId })
  .from(wpTermTaxonomy)
  .where(and(eq(wpTermTaxonomy.termId, menuId), eq(wpTermTaxonomy.taxonomy, "nav_menu")))
  .limit(1);

const rawItems = tt ? await db
  .select({ id: wpPosts.id, title: wpPosts.postTitle, order: wpPosts.menuOrder, parent: wpPosts.postParent })
  .from(wpPosts)
  .innerJoin(wpTermRelationships, eq(wpTermRelationships.objectId, wpPosts.id))
  .where(and(
    eq(wpPosts.postType, "nav_menu_item"),
    eq(wpPosts.postStatus, "publish"),
    eq(wpTermRelationships.termTaxonomyId, tt.id)
  ))
  .orderBy(wpPosts.menuOrder)
: [];

let urlMap: Record<number, string> = {};
if (rawItems.length > 0) {
  const metas = await db
    .select({ postId: wpPostmeta.postId, metaValue: wpPostmeta.metaValue })
    .from(wpPostmeta)
    .where(eq(wpPostmeta.metaKey, "_menu_item_url"));
  for (const m of metas) {
    if (rawItems.some(i => i.id === m.postId)) urlMap[m.postId] = m.metaValue ?? "";
  }
}

const menuItems = rawItems.map(i => ({ ...i, url: urlMap[i.id] ?? "" }));

// Quick-add: pages and posts
const quickPages = await db
  .select({ id: wpPosts.id, title: wpPosts.postTitle, slug: wpPosts.postName })
  .from(wpPosts)
  .where(and(eq(wpPosts.postType, "page"), eq(wpPosts.postStatus, "publish")))
  .limit(50);

const quickPosts = await db
  .select({ id: wpPosts.id, title: wpPosts.postTitle, slug: wpPosts.postName })
  .from(wpPosts)
  .where(and(eq(wpPosts.postType, "post"), eq(wpPosts.postStatus, "publish")))
  .limit(50);

const itemsJson = JSON.stringify(menuItems);
---
<AdminLayout title={`Edit Menu: ${menu.name}`}>
  <style>
    .menu-item { display:flex; align-items:center; gap:8px; padding:10px 14px; background:#fff; border:1px solid #dcdcde; border-radius:4px; margin-bottom:4px; cursor:grab; user-select:none; }
    .menu-item:active { cursor:grabbing; }
    .menu-item.drag-over { border-color:#2271b1; background:#f0f6fc; }
    .menu-item.dragging { opacity:0.4; }
    .item-handle { color:#ccc; font-size:16px; flex-shrink:0; }
    .item-body { flex:1; min-width:0; }
    .item-title { font-size:13px; font-weight:600; color:#1d2327; }
    .item-url { font-size:11px; color:#646970; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .item-depth { flex-shrink:0; }
    .item-actions { display:flex; gap:4px; flex-shrink:0; }
    .item-actions button { padding:3px 8px; border:1px solid #dcdcde; background:#fff; border-radius:3px; cursor:pointer; font-size:11px; color:#3c434a; }
    .item-actions button:hover { background:#f6f7f7; }
    .item-actions button.danger { color:#dc3232; border-color:#dc3232; }
    .indent-bar { display:inline-block; width:24px; height:4px; background:#dcdcde; border-radius:2px; vertical-align:middle; margin-right:4px; }
    .panel { background:#fff; border:1px solid #dcdcde; border-radius:8px; overflow:hidden; margin-bottom:12px; }
    .panel-head { background:#f6f7f7; padding:10px 14px; font-size:13px; font-weight:600; border-bottom:1px solid #dcdcde; display:flex; justify-content:space-between; align-items:center; cursor:pointer; }
    .panel-body { padding:14px; }
    .quick-item { display:flex; align-items:center; gap:8px; padding:4px 0; font-size:12px; }
    .field { margin-bottom:10px; }
    .field label { display:block; font-size:12px; font-weight:600; margin-bottom:3px; }
    .field input { width:100%; padding:6px 8px; font-size:13px; border:1px solid #8c8f94; border-radius:3px; box-sizing:border-box; }
    .btn-primary { padding:7px 16px; background:#2271b1; color:#fff; border:none; border-radius:3px; font-size:13px; cursor:pointer; font-weight:600; }
    .btn-primary:hover { background:#135e96; }
    .empty-state { padding:32px; text-align:center; color:#646970; font-size:13px; }
  </style>

  <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
    <a href="/admin/menus" style="font-size:13px;color:#646970;text-decoration:none">← Menus</a>
    <div style="display:flex;align-items:center;gap:8px;flex:1">
      <input id="menu-name-input" type="text" value={menu.name}
        style="font-size:20px;font-weight:700;border:none;border-bottom:2px solid transparent;padding:2px 4px;outline:none;background:transparent;color:#1d2327;min-width:200px"
        onfocus="this.style.borderBottomColor='#2271b1'"
        onblur="this.style.borderBottomColor='transparent';saveName(this.value)" />
      <span id="slug-badge" style="font-size:11px;color:#646970;background:#f0f0f1;padding:2px 8px;border-radius:10px">slug: {menu.slug}</span>
    </div>
    <button onclick="deleteThisMenu()" style="padding:6px 14px;background:#fff;color:#dc3232;border:1px solid #dc3232;border-radius:3px;font-size:12px;cursor:pointer">Delete Menu</button>
  </div>

  <div style="display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start">
    <!-- Left: menu builder -->
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
        <span style="font-size:13px;font-weight:600;color:#3c434a">Menu Structure</span>
        <button id="btn-save-order" onclick="saveOrder()" class="btn-primary" style="padding:6px 14px;font-size:12px;">Save Menu</button>
      </div>

      <div id="items-list" style="min-height:80px">
        {menuItems.length === 0
          ? <div class="empty-state" id="empty-msg">Add menu items from the panel on the right →</div>
          : menuItems.map(item => (
            <div class="menu-item" draggable="true" data-id={item.id} data-parent={item.parent} data-order={item.order}>
              <span class="item-handle">⠿</span>
              <div class="item-depth">
                {Array.from({ length: Math.min(item.parent > 0 ? 1 : 0, 3) }, () => (
                  <span class="indent-bar"></span>
                ))}
              </div>
              <div class="item-body">
                <div class="item-title" contenteditable="true" spellcheck="false"
                  onblur={`renameItem(${item.id}, this.textContent)`}>{item.title}</div>
                <div class="item-url">{item.url}</div>
              </div>
              <div class="item-actions">
                <button onclick={`indentItem(${item.id})`} title="Make sub-item">↳</button>
                <button onclick={`outdentItem(${item.id})`} title="Remove sub-item">←</button>
                <button onclick={`removeItem(${item.id})`} class="danger">✕</button>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Right: add items -->
    <aside>
      <!-- Custom link -->
      <div class="panel">
        <div class="panel-head" onclick="togglePanel('custom')">
          Custom Link <span id="custom-arrow">▾</span>
        </div>
        <div class="panel-body" id="panel-custom">
          <div class="field"><label>URL</label><input id="cust-url" type="url" placeholder="https://example.com" /></div>
          <div class="field"><label>Link Text</label><input id="cust-label" type="text" placeholder="Link text" /></div>
          <button class="btn-primary" onclick="addCustom()" style="width:100%">Add to Menu</button>
        </div>
      </div>

      <!-- Pages -->
      {quickPages.length > 0 && (
        <div class="panel">
          <div class="panel-head" onclick="togglePanel('pages')">
            Pages <span id="pages-arrow">▾</span>
          </div>
          <div class="panel-body" id="panel-pages">
            <div style="max-height:200px;overflow-y:auto;margin-bottom:10px">
              {quickPages.map(p => (
                <label class="quick-item">
                  <input type="checkbox" class="page-chk" value={p.id} data-title={p.title} data-url={`/${p.slug}`} />
                  {p.title}
                </label>
              ))}
            </div>
            <button class="btn-primary" onclick="addChecked('page-chk')" style="width:100%">Add Selected</button>
          </div>
        </div>
      )}

      <!-- Posts -->
      {quickPosts.length > 0 && (
        <div class="panel">
          <div class="panel-head" onclick="togglePanel('posts')">
            Posts <span id="posts-arrow">▾</span>
          </div>
          <div class="panel-body" id="panel-posts">
            <div style="max-height:200px;overflow-y:auto;margin-bottom:10px">
              {quickPosts.map(p => (
                <label class="quick-item">
                  <input type="checkbox" class="post-chk" value={p.id} data-title={p.title} data-url={`/blog/${p.slug}`} />
                  {p.title}
                </label>
              ))}
            </div>
            <button class="btn-primary" onclick="addChecked('post-chk')" style="width:100%">Add Selected</button>
          </div>
        </div>
      )}
    </aside>
  </div>

  <script define:vars={{ menuId, initialItems: itemsJson }}>
    // ── State ────────────────────────────────────────────────────────────────
    let items = JSON.parse(initialItems);

    // ── Render ───────────────────────────────────────────────────────────────
    function render() {
      const list = document.getElementById('items-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="empty-state">Add menu items from the panel on the right →</div>';
        return;
      }
      list.innerHTML = items.map(item => {
        const depth = item.parent > 0 ? 1 : 0;
        const depthBar = depth > 0 ? '<span class="indent-bar"></span>' : '';
        return `<div class="menu-item" draggable="true" data-id="${item.id}" data-parent="${item.parent}" data-order="${item.order}">
          <span class="item-handle">⠿</span>
          <div class="item-depth">${depthBar}</div>
          <div class="item-body">
            <div class="item-title" contenteditable="true" spellcheck="false"
              onblur="renameItem(${item.id}, this.textContent)">${esc(item.title)}</div>
            <div class="item-url">${esc(item.url)}</div>
          </div>
          <div class="item-actions">
            <button onclick="indentItem(${item.id})" title="Make sub-item">↳</button>
            <button onclick="outdentItem(${item.id})" title="Remove sub-item">←</button>
            <button onclick="removeItem(${item.id})" class="danger">✕</button>
          </div>
        </div>`;
      }).join('');
      initDrag();
    }

    function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // ── Drag-and-drop reorder ─────────────────────────────────────────────
    let dragId = null;
    function initDrag() {
      document.querySelectorAll('.menu-item').forEach(el => {
        el.addEventListener('dragstart', e => { dragId = Number(el.dataset.id); el.classList.add('dragging'); });
        el.addEventListener('dragend', () => { el.classList.remove('dragging'); document.querySelectorAll('.menu-item').forEach(x => x.classList.remove('drag-over')); });
        el.addEventListener('dragover', e => { e.preventDefault(); el.classList.add('drag-over'); });
        el.addEventListener('dragleave', () => el.classList.remove('drag-over'));
        el.addEventListener('drop', e => {
          e.preventDefault();
          el.classList.remove('drag-over');
          const targetId = Number(el.dataset.id);
          if (dragId === targetId) return;
          const fromIdx = items.findIndex(i => i.id === dragId);
          const toIdx = items.findIndex(i => i.id === targetId);
          const [moved] = items.splice(fromIdx, 1);
          items.splice(toIdx, 0, moved);
          items.forEach((item, i) => { item.order = i + 1; });
          render();
        });
      });
    }
    initDrag();

    // ── Indent / Outdent ─────────────────────────────────────────────────
    function indentItem(id) {
      const idx = items.findIndex(i => i.id === id);
      if (idx <= 0) return; // can't indent first item
      items[idx].parent = items[idx - 1].id;
      render();
    }
    function outdentItem(id) {
      const item = items.find(i => i.id === id);
      if (item) item.parent = 0;
      render();
    }
    window.indentItem = indentItem;
    window.outdentItem = outdentItem;

    // ── Save order ───────────────────────────────────────────────────────
    async function saveOrder() {
      const btn = document.getElementById('btn-save-order');
      btn.textContent = 'Saving…'; btn.disabled = true;
      await fetch(`/api/menus/${menuId}/items`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(items.map((item, i) => ({ id: item.id, menuOrder: i + 1, postParent: item.parent || 0 }))),
      });
      btn.textContent = 'Saved ✓'; btn.disabled = false;
      setTimeout(() => { btn.textContent = 'Save Menu'; }, 2000);
    }
    window.saveOrder = saveOrder;

    // ── Rename item ──────────────────────────────────────────────────────
    async function renameItem(id, newTitle) {
      const t = (newTitle || '').trim();
      if (!t) return;
      const item = items.find(i => i.id === id);
      if (item) item.title = t;
      await fetch(`/api/menus/${menuId}/items/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: t }),
      });
    }
    window.renameItem = renameItem;

    // ── Remove item ──────────────────────────────────────────────────────
    async function removeItem(id) {
      await fetch(`/api/menus/${menuId}/items/${id}`, { method: 'DELETE' });
      // Also remove any children
      items = items.filter(i => i.id !== id && i.parent !== id);
      render();
    }
    window.removeItem = removeItem;

    // ── Add custom link ──────────────────────────────────────────────────
    async function addCustom() {
      const url = document.getElementById('cust-url').value.trim();
      const label = document.getElementById('cust-label').value.trim();
      if (!url || !label) return;
      const r = await fetch(`/api/menus/${menuId}/items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, title: label }),
      });
      const { id } = await r.json();
      items.push({ id, title: label, url, order: items.length + 1, parent: 0 });
      document.getElementById('cust-url').value = '';
      document.getElementById('cust-label').value = '';
      render();
    }
    window.addCustom = addCustom;

    // ── Add checked items (pages/posts) ───────────────────────────────────
    async function addChecked(cls) {
      const checked = Array.from(document.querySelectorAll(`.${cls}:checked`));
      for (const cb of checked) {
        const r = await fetch(`/api/menus/${menuId}/items`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: cb.dataset.url, title: cb.dataset.title }),
        });
        const { id } = await r.json();
        items.push({ id, title: cb.dataset.title, url: cb.dataset.url, order: items.length + 1, parent: 0 });
        cb.checked = false;
      }
      render();
    }
    window.addChecked = addChecked;

    // ── Rename menu ──────────────────────────────────────────────────────
    async function saveName(name) {
      const t = (name || '').trim();
      if (!t) return;
      const r = await fetch(`/api/menus/${menuId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: t }),
      });
      const { slug } = await r.json();
      document.getElementById('slug-badge').textContent = `slug: ${slug}`;
    }
    window.saveName = saveName;

    // ── Delete menu ──────────────────────────────────────────────────────
    async function deleteThisMenu() {
      const name = document.getElementById('menu-name-input').value;
      if (!confirm(`Delete menu "${name}" and all its items? This cannot be undone.`)) return;
      await fetch(`/api/menus/${menuId}`, { method: 'DELETE' });
      window.location.href = '/admin/menus';
    }
    window.deleteThisMenu = deleteThisMenu;

    // ── Panel toggles ────────────────────────────────────────────────────
    const panels = { custom: true, pages: true, posts: true };
    function togglePanel(name) {
      panels[name] = !panels[name];
      const el = document.getElementById(`panel-${name}`);
      const arrow = document.getElementById(`${name}-arrow`);
      if (el) el.style.display = panels[name] ? 'block' : 'none';
      if (arrow) arrow.textContent = panels[name] ? '▾' : '▸';
    }
    window.togglePanel = togglePanel;
  </script>
</AdminLayout>
