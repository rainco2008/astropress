---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listMedia } from "../../../lib/media";

const db = Astro.locals.db;
const page = Number(Astro.url.searchParams.get("page") ?? "1");

const { items, total } = db
  ? await listMedia(db, { page })
  : { items: [], total: 0 };

const perPage = 40;
const totalPages = Math.ceil(total / perPage);
---
<AdminLayout title="Media Library">

  <h1 class="wp-heading-inline">Media Library</h1>
  <label class="page-title-action" style="cursor:pointer">
    Add New
    <input id="upload-input" type="file" accept="image/*,video/*,application/pdf" multiple style="display:none" onchange="handleUpload(this)" />
  </label>
  <hr class="wp-header-end" />

  <div id="upload-progress" style="display:none;background:#fff;border:1px solid #dcdcde;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#646970;max-width:480px">
    Uploading…
  </div>

  {items.length === 0 ? (
    <div class="ap-empty-state">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="color:#8c8f94;margin-bottom:12px">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
      <h2 style="font-size:15px;font-weight:600;color:#1d2327;margin:0 0 8px">No Media Yet</h2>
      <p style="font-size:13px;color:#646970;margin:0 0 20px;line-height:1.5">
        Upload images, videos, and documents to use in your content.
      </p>
      <label class="button button-primary" style="cursor:pointer">
        Upload Your First File
        <input type="file" accept="image/*" style="display:none" onchange="handleUpload(this)" />
      </label>
    </div>
  ) : (
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px" id="media-grid">
      {items.map((item) => (
        <div
          class="media-item"
          data-id={item.id}
          style="background:#fff;border:1px solid #dcdcde;border-radius:2px;overflow:hidden;cursor:pointer;transition:border-color 0.15s"
          onclick="selectItem(this)"
        >
          {item.mimeType.startsWith("image/") ? (
            <img
              src={item.url}
              alt={item.title}
              style="width:100%;height:120px;object-fit:cover;display:block"
              loading="lazy"
            />
          ) : (
            <div style="width:100%;height:120px;display:flex;align-items:center;justify-content:center;background:#f6f7f7">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8c8f94" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
          )}
          <div style="padding:8px">
            <div style="font-size:11px;font-weight:600;color:#1d2327;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{item.title || item.filename}</div>
            <div style="font-size:10px;color:#646970;margin-top:2px">{item.mimeType}</div>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Item details panel -->
  <div id="item-details" style="display:none;position:fixed;top:0;right:0;width:300px;height:100vh;background:#fff;border-left:1px solid #dcdcde;padding:20px;overflow-y:auto;z-index:100;box-shadow:-4px 0 12px rgba(0,0,0,.08)">
    <button onclick="closeDetails()" style="position:absolute;top:12px;right:12px;background:none;border:none;font-size:18px;cursor:pointer;color:#646970;line-height:1">&#x2715;</button>
    <div id="details-content"></div>
  </div>

  {totalPages > 1 && (
    <div class="tablenav bottom">
      <div class="tablenav-pages">
        {Array.from({length: totalPages}, (_, i) => i + 1).map((p) => (
          <a
            href={`/admin/medias?page=${p}`}
            class={p === page ? "button button-disabled" : "button"}
            style={p === page ? "font-weight:700" : ""}
          >
            {p}
          </a>
        ))}
      </div>
    </div>
  )}

  <script>
    async function handleUpload(input: HTMLInputElement) {
      const files = Array.from(input.files ?? []);
      if (!files.length) return;

      const progress = document.getElementById("upload-progress") as HTMLElement | null;
      if (!progress) return;
      progress.style.display = "block";

      for (const file of files) {
        progress.textContent = `Uploading ${file.name}…`;
        const form = new FormData();
        form.append("file", file);
        await fetch("/api/media/upload", { method: "POST", body: form });
      }

      progress.textContent = "Done! Refreshing…";
      setTimeout(() => location.reload(), 800);
    }

    function selectItem(el: HTMLElement) {
      document.querySelectorAll(".media-item").forEach((i) => (i as HTMLElement).style.borderColor = "#dcdcde");
      el.style.borderColor = "#2271b1";
      const title = el.querySelector("div div:first-child")?.textContent ?? "";
      const imgSrc = (el.querySelector("img") as HTMLImageElement | null)?.src ?? "";
      const mime = el.querySelector("div div:last-child")?.textContent ?? "";
      const details = document.getElementById("details-content") as HTMLElement | null;
      if (!details) return;
      details.innerHTML = `
        ${imgSrc ? `<img src="${imgSrc}" style="width:100%;border-radius:2px;margin-bottom:12px" />` : ""}
        <div style="font-size:13px;font-weight:600;margin-bottom:6px">${title}</div>
        <div style="font-size:11px;color:#646970;margin-bottom:12px">${mime}</div>
        <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">URL</label>
        <input type="text" value="${imgSrc}" readonly style="width:100%;font-size:11px;padding:6px 8px;border:1px solid #dcdcde;border-radius:2px" onclick="this.select()" />
      `;
      const itemDetails = document.getElementById("item-details") as HTMLElement | null;
      if (itemDetails) itemDetails.style.display = "block";
    }

    function closeDetails() {
      const itemDetails = document.getElementById("item-details") as HTMLElement | null;
      if (itemDetails) itemDetails.style.display = "none";
      document.querySelectorAll(".media-item").forEach((i) => (i as HTMLElement).style.borderColor = "#dcdcde");
    }
  </script>

</AdminLayout>

