---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listPosts } from "../../../lib/posts";

const db = Astro.locals.db;
const status = Astro.url.searchParams.get("status") ?? undefined;
const page = Number(Astro.url.searchParams.get("page") ?? "1");

const { posts, total } = db
  ? await listPosts(db, { type: "post", status, page })
  : { posts: [], total: 0 };

const perPage = 20;
const totalPages = Math.ceil(total / perPage);

const statusOptions = [
  { value: "", label: "All" },
  { value: "publish", label: "Published" },
  { value: "draft", label: "Draft" },
  { value: "trash", label: "Trash" },
];
---
<AdminLayout title="Posts">
  <div class="wp-heading">
    <h1>Posts</h1>
    <a href="/admin/posts/new" class="button-primary button-small">+ New Post</a>
  </div>

  <ul class="subsubsub">
    {statusOptions.map((s) => (
      <li>
        <a
          href={s.value ? `/admin/posts?status=${s.value}` : "/admin/posts"}
          class={(status ?? "") === s.value ? "current" : ""}
        >
          {s.label}
        </a>
      </li>
    ))}
  </ul>

  {posts.length === 0 ? (
    <div class="postbox">
      <div class="postbox-inside" style="padding:40px;text-align:center;color:var(--wp-gray-500)">
        No posts found.{" "}
        <a href="/admin/posts/new" class="button-link">Create your first post →</a>
      </div>
    </div>
  ) : (
    <table class="wp-list-table">
      <thead>
        <tr>
          <th style="width:50%">Title</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post) => (
          <tr>
            <td class="column-title">
              <a href={`/admin/posts/${post.id}`} style="color:var(--wp-gray-900);text-decoration:none">
                {post.title || <em style="color:var(--wp-gray-500);font-weight:400">Untitled</em>}
              </a>
              <div class="row-actions">
                <span><a href={`/admin/posts/${post.id}`}>Edit</a></span>
                <span class="delete">
                  <a
                    onclick={`if(confirm('Move to trash?'))fetch('/api/posts/${post.id}',{method:'DELETE'}).then(()=>location.reload())`}
                    style="cursor:pointer"
                  >Trash</a>
                </span>
              </div>
            </td>
            <td>
              <span class={`status-badge status-${post.status}`}>
                {post.status === "publish" ? "Published"
                  : post.status.charAt(0).toUpperCase() + post.status.slice(1)}
              </span>
            </td>
            <td style="color:var(--wp-gray-500);font-size:12px;white-space:nowrap">
              {post.date.slice(0, 10)}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  {totalPages > 1 && (
    <div style="display:flex;gap:4px;margin-top:16px">
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
        <a
          href={`/admin/posts?page=${p}${status ? `&status=${status}` : ""}`}
          class={p === page ? "button-primary button-small" : "button button-small"}
        >
          {p}
        </a>
      ))}
    </div>
  )}
</AdminLayout>
