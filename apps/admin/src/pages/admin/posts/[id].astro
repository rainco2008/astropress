---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getPost } from "../../../lib/posts";
import BlockEditor from "../../../islands/BlockEditor";
import { getSidebarPanels } from "@astropress/core/registry";
import SeoPanel from "../../../islands/SeoPanel";
import CustomFieldsPanel from "../../../islands/CustomFieldsPanel";

const db = Astro.locals.db;
const user = Astro.locals.user;
const id = Number(Astro.params.id);

if (!db || !user) return Astro.redirect("/login");

const post = await getPost(db, id);
if (!post) return Astro.redirect("/admin/posts");

const panels = getSidebarPanels("post");
---
<AdminLayout
  title={post.title || "Edit Post"}
  pageContext={{ postId: id, postType: "post", postStatus: post.status }}
>
  <div id="editor-root"
    data-post-id={String(id)}
    data-initial-slug={post.slug ?? ""}
    style="display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start">

    <!-- Left: Title + Block editor -->
    <div>
      <input
        id="post-title"
        type="text"
        placeholder="Add title"
        value={post.title}
        class="wp-post-title-input"
        oninput="updateSlug(this.value)"
      />
      <div style="font-size:12px;color:var(--wp-gray-500);margin-bottom:16px">
        Permalink: <span id="permalink-display" style="color:var(--wp-blue)">/{post.slug || "..."}</span>
        <input id="post-slug" type="hidden" value={post.slug} />
      </div>

      <div class="postbox" style="overflow:hidden;min-height:480px">
        <BlockEditor
          client:only="react"
          initialContent={post.content}
          postId={id}
        />
      </div>

      <!-- Excerpt -->
      <div class="postbox" style="margin-top:16px">
        <div class="postbox-header"><h2 class="postbox-title">Excerpt</h2></div>
        <div class="postbox-inside">
          <textarea
            id="post-excerpt"
            rows="3"
            placeholder="Optional excerpt…"
            class="wp-textarea"
            style="width:100%"
          >{post.excerpt}</textarea>
        </div>
      </div>

      <!-- Custom Fields -->
      <div style="margin-top:16px">
        <CustomFieldsPanel client:only="react" postId={id} postType="post" />
      </div>
    </div>

    <!-- Right sidebar -->
    <aside>
      <!-- Publish box -->
      <div class="postbox">
        <div class="postbox-header"><h2 class="postbox-title">Publish</h2></div>
        <div class="postbox-inside">
          <div style="margin-bottom:12px">
            <label class="wp-form-label">Visibility</label>
            <select id="post-status" class="wp-select" style="width:100%">
              <option value="draft" selected={post.status === "draft"}>Draft</option>
              <option value="publish" selected={post.status === "publish"}>Published</option>
              <option value="private" selected={post.status === "private"}>Private</option>
            </select>
          </div>

          <div id="save-status" style="font-size:11px;color:var(--wp-gray-500);margin-bottom:10px;min-height:14px"></div>

          <div style="display:flex;gap:6px">
            <button onclick="savePost('draft')" class="button" style="flex:1;justify-content:center">Save Draft</button>
            <button onclick="savePost('publish')" class="button-primary" style="flex:1;justify-content:center">Publish</button>
          </div>

          <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--wp-gray-100)">
            <button
              onclick={`if(confirm('Move to trash?')) { fetch('/api/posts/${id}', {method:'DELETE'}).then(() => location.href='/admin/posts') }`}
              class="button-link-delete"
              style="font-size:12px"
            >
              Move to Trash
            </button>
          </div>
        </div>
      </div>

      <!-- View post link -->
      {post.status === "publish" && (
        <div class="postbox">
          <div class="postbox-inside" style="font-size:12px">
            <a href={`/${post.slug}`} target="_blank" class="button-link">View post →</a>
          </div>
        </div>
      )}

      <!-- Plugin sidebar panels -->
      {panels.map((panel) => (
        <div class="postbox">
          <div class="postbox-header">
            <h2 class="postbox-title">{panel.config.title}</h2>
          </div>
          <div class="postbox-inside">
            {panel.config.componentId === "SeoPanel" && (
              <SeoPanel client:only="react" postId={id} />
            )}
          </div>
        </div>
      ))}
    </aside>
  </div>

  <script is:inline>
    (function () {
      var root = document.getElementById("editor-root");
      var postId = root.dataset.postId;
      var currentSlug = root.dataset.initialSlug;

      function slugify(str) {
        return str.toLowerCase().trim()
          .replace(/[^\w\s-]/g, "")
          .replace(/[\s_]+/g, "-")
          .replace(/^-+|-+$/g, "");
      }

      window.updateSlug = function (title) {
        var titleEl = document.getElementById("post-title");
        if (!currentSlug || currentSlug === slugify(titleEl.defaultValue)) {
          currentSlug = slugify(title);
          document.getElementById("permalink-display").textContent = "/" + (currentSlug || "...");
          document.getElementById("post-slug").value = currentSlug;
        }
      };

      window.savePost = async function (forceStatus) {
        var title = document.getElementById("post-title").value;
        var status = forceStatus || document.getElementById("post-status").value;
        var slug = document.getElementById("post-slug").value || slugify(title);
        var excerpt = document.getElementById("post-excerpt").value;
        var content = window.__editorContent || "";

        document.getElementById("save-status").textContent = "Saving\u2026";

        try {
          var res = await fetch("/api/posts/" + postId, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title: title, content: content, excerpt: excerpt, status: status, slug: slug }),
          });
          if (res.ok) {
            document.getElementById("save-status").textContent = "Saved \u2713";
            document.getElementById("post-status").value = status;
            setTimeout(function () { document.getElementById("save-status").textContent = ""; }, 3000);
          } else {
            document.getElementById("save-status").textContent = "Error saving";
          }
        } catch (e) {
          document.getElementById("save-status").textContent = "Error saving";
        }
      };

      setInterval(function () {
        var title = document.getElementById("post-title").value;
        if (title) window.savePost(null);
      }, 60000);
    })();
  </script>
</AdminLayout>
