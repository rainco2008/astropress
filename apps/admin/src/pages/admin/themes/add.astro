---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

const REGISTRY_URL = "https://raw.githubusercontent.com/astropress/themes/main/registry.json";
---
<AdminLayout title="Add Theme">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
    <h1 class="wp-heading-inline" style="margin:0">Add New Theme</h1>
    <a href="/admin/themes" class="button">← Back to Themes</a>
  </div>
  <hr class="wp-header-end" />

  <!-- Tabs -->
  <div style="margin-bottom:24px">
    <nav class="nav-tab-wrapper">
      <a id="tab-upload-btn" class="nav-tab nav-tab-active" onclick="switchTab('upload');return false;" href="#" style="cursor:pointer">Upload Theme</a>
      <a id="tab-browse-btn" class="nav-tab" onclick="switchTab('browse');return false;" href="#" style="cursor:pointer">Browse Themes</a>
    </nav>
  </div>

  <!-- Upload Tab -->
  <div id="tab-upload">
    <div style="max-width:640px">
      <div style="background:#fff;border:1px solid #dcdcde;border-radius:4px;padding:28px">
        <h2 style="margin:0 0 6px;font-size:16px">Upload a Theme File</h2>
        <p style="margin:0 0 20px;color:#646970;font-size:13px">Upload a <code>.zip</code> or <code>.json</code> theme file exported from AstroPress.</p>

        <div id="upload-area" style="border:2px dashed #dcdcde;border-radius:4px;padding:40px 24px;text-align:center;cursor:pointer;transition:border-color 0.15s" onclick="document.getElementById('file-input').click()">
          <div style="font-size:32px;margin-bottom:8px">📦</div>
          <div style="font-weight:600;margin-bottom:4px">Drop file here or click to browse</div>
          <div style="font-size:12px;color:#646970">.zip or .json — max 10MB</div>
        </div>
        <input type="file" id="file-input" accept=".zip,.json" style="display:none" />

        <div id="upload-error" style="display:none;margin-top:12px;color:#d63638;font-size:13px;padding:8px 12px;background:#fdf2f2;border:1px solid #facaca;border-radius:4px"></div>
      </div>

      <!-- Preview (shown after file is parsed) -->
      <div id="preview-section" style="display:none;margin-top:20px;background:#fff;border:1px solid #dcdcde;border-radius:4px;padding:24px">
        <h2 style="margin:0 0 16px;font-size:16px">Theme Preview</h2>

        <!-- Color swatches -->
        <div id="preview-swatches" style="height:60px;display:grid;grid-template-columns:repeat(7,1fr);border-radius:4px;overflow:hidden;margin-bottom:16px"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
          <div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#646970;margin-bottom:4px">Name</div>
            <div id="preview-name" style="font-weight:600"></div>
          </div>
          <div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#646970;margin-bottom:4px">Author</div>
            <div id="preview-author" style="color:#646970"></div>
          </div>
          <div style="grid-column:1/-1">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#646970;margin-bottom:4px">Description</div>
            <div id="preview-desc" style="color:#646970;font-size:13px"></div>
          </div>
        </div>

        <!-- What's included -->
        <div id="preview-includes" style="margin-bottom:20px;padding:12px 16px;background:#f6f7f7;border-radius:4px;font-size:13px"></div>

        <!-- Create pages checkbox -->
        <div id="create-pages-section" style="display:none;margin-bottom:20px;padding:14px 16px;background:#f0f6fc;border:1px solid #c3d7f7;border-radius:4px">
          <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer">
            <input type="checkbox" id="create-pages-cb" checked style="margin-top:2px;width:16px;height:16px;flex-shrink:0" />
            <div>
              <div style="font-weight:600;margin-bottom:2px">Create pages from theme</div>
              <div style="font-size:12px;color:#646970" id="pages-list-desc"></div>
            </div>
          </label>
        </div>

        <div style="display:flex;gap:8px">
          <button id="install-btn" onclick="installTheme()" class="button button-primary">Install Theme</button>
          <button onclick="resetUpload()" class="button">Cancel</button>
        </div>
        <div id="install-status" style="display:none;margin-top:10px;font-size:13px;color:#646970"></div>
      </div>
    </div>
  </div>

  <!-- Browse Tab -->
  <div id="tab-browse" style="display:none">
    <div id="browse-loading" style="text-align:center;padding:60px 20px;color:#646970">
      <div style="font-size:24px;margin-bottom:8px">🔄</div>
      Loading themes from registry…
    </div>
    <div id="browse-error" style="display:none;max-width:640px;padding:20px;background:#fff;border:1px solid #dcdcde;border-radius:4px;text-align:center;color:#646970">
      <div style="font-size:24px;margin-bottom:8px">🔌</div>
      <div style="font-weight:600;margin-bottom:4px">No themes available yet</div>
      <div style="font-size:13px">The theme registry is not configured or unreachable. Check back later.</div>
    </div>
    <div id="browse-grid" style="display:none;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px"></div>
  </div>

</AdminLayout>

<!-- Install from Browse modal -->
<div id="browse-install-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;z-index:9999">
  <div style="background:#fff;border-radius:6px;padding:28px;width:420px;max-width:90vw">
    <h2 style="margin:0 0 14px;font-size:16px" id="browse-install-title">Install Theme</h2>
    <div id="browse-install-pages-section" style="display:none;margin-bottom:20px;padding:14px 16px;background:#f0f6fc;border:1px solid #c3d7f7;border-radius:4px">
      <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer">
        <input type="checkbox" id="browse-create-pages-cb" checked style="margin-top:2px;width:16px;height:16px;flex-shrink:0" />
        <div>
          <div style="font-weight:600;margin-bottom:2px">Create pages from theme</div>
          <div id="browse-pages-desc" style="font-size:12px;color:#646970"></div>
        </div>
      </label>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button onclick="document.getElementById('browse-install-modal').style.display='none'" class="button">Cancel</button>
      <button id="browse-install-btn" onclick="confirmBrowseInstall()" class="button button-primary">Install</button>
    </div>
    <div id="browse-install-status" style="display:none;margin-top:10px;font-size:13px;color:#646970"></div>
  </div>
</div>

<script is:inline define:vars={{ REGISTRY_URL }}>
(function () {
  var pendingPackage = null;
  var pendingBrowsePackage = null;

  // ── Tab switching ──────────────────────────────────────────────────────────
  window.switchTab = function(tab) {
    document.getElementById('tab-upload').style.display = tab === 'upload' ? 'block' : 'none';
    document.getElementById('tab-browse').style.display = tab === 'browse' ? 'block' : 'none';
    document.getElementById('tab-upload-btn').className = 'nav-tab' + (tab === 'upload' ? ' nav-tab-active' : '');
    document.getElementById('tab-browse-btn').className = 'nav-tab' + (tab === 'browse' ? ' nav-tab-active' : '');
    if (tab === 'browse' && !window._browseLoaded) loadBrowse();
  };

  // ── Upload tab ─────────────────────────────────────────────────────────────
  var uploadArea = document.getElementById('upload-area');
  var fileInput = document.getElementById('file-input');

  uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); uploadArea.style.borderColor = '#2271b1'; });
  uploadArea.addEventListener('dragleave', function() { uploadArea.style.borderColor = '#dcdcde'; });
  uploadArea.addEventListener('drop', function(e) {
    e.preventDefault();
    uploadArea.style.borderColor = '#dcdcde';
    var f = e.dataTransfer.files[0];
    if (f) handleFile(f);
  });
  fileInput.addEventListener('change', function() { if (fileInput.files[0]) handleFile(fileInput.files[0]); });

  function showUploadError(msg) {
    var el = document.getElementById('upload-error');
    el.textContent = msg;
    el.style.display = 'block';
  }

  function handleFile(file) {
    document.getElementById('upload-error').style.display = 'none';
    document.getElementById('preview-section').style.display = 'none';
    uploadArea.style.borderColor = '#2271b1';

    var fd = new FormData();
    fd.append('file', file);

    fetch('/api/themes/upload', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        uploadArea.style.borderColor = '#dcdcde';
        if (!data.ok) { showUploadError(data.error || 'Failed to parse file'); return; }
        pendingPackage = data.package;
        showPreview(data.preview);
      })
      .catch(function() { uploadArea.style.borderColor = '#dcdcde'; showUploadError('Upload failed. Please try again.'); });
  }

  function showPreview(preview) {
    // Swatches
    var c = preview.tokens.colors;
    var swatchOrder = [c.primary, c.secondary, c.background, c.surface, c.text, c.textMuted, c.border];
    document.getElementById('preview-swatches').innerHTML = swatchOrder.map(function(col) {
      return '<div style="background:' + col + '"></div>';
    }).join('');

    document.getElementById('preview-name').textContent = preview.name || '—';
    document.getElementById('preview-author').textContent = preview.author || '—';
    document.getElementById('preview-desc').textContent = preview.description || '—';

    var parts = [];
    if (preview.templateCount > 0) parts.push(preview.templateCount + ' template' + (preview.templateCount !== 1 ? 's' : '') + ' (' + preview.templates.map(function(t) { return t.type; }).join(', ') + ')');
    if (preview.pageCount > 0) parts.push(preview.pageCount + ' page' + (preview.pageCount !== 1 ? 's' : '') + ' (' + preview.pages.map(function(p) { return p.title || p.slug; }).join(', ') + ')');
    document.getElementById('preview-includes').innerHTML = parts.length > 0
      ? '<strong>Includes:</strong> ' + parts.join(' &nbsp;·&nbsp; ')
      : '<span style="color:#646970">No templates or pages included</span>';

    if (preview.pageCount > 0) {
      document.getElementById('pages-list-desc').textContent = 'Pages that will be created: ' + preview.pages.map(function(p) { return p.title || p.slug; }).join(', ');
      document.getElementById('create-pages-section').style.display = 'block';
    } else {
      document.getElementById('create-pages-section').style.display = 'none';
    }

    document.getElementById('install-status').style.display = 'none';
    document.getElementById('preview-section').style.display = 'block';
  }

  window.resetUpload = function() {
    pendingPackage = null;
    fileInput.value = '';
    document.getElementById('preview-section').style.display = 'none';
    document.getElementById('upload-error').style.display = 'none';
  };

  window.installTheme = function() {
    if (!pendingPackage) return;
    var createPages = document.getElementById('create-pages-cb').checked;
    doInstall(pendingPackage, createPages, 'install-btn', 'install-status', function() {
      window.location.href = '/admin/themes';
    });
  };

  // ── Browse tab ─────────────────────────────────────────────────────────────
  window._browseLoaded = false;

  function loadBrowse() {
    window._browseLoaded = true;
    fetch(REGISTRY_URL)
      .then(function(r) { if (!r.ok) throw new Error('Registry unreachable'); return r.json(); })
      .then(function(data) {
        var themes = data.themes || data;
        document.getElementById('browse-loading').style.display = 'none';
        if (!Array.isArray(themes) || themes.length === 0) {
          document.getElementById('browse-error').style.display = 'block';
          return;
        }
        var grid = document.getElementById('browse-grid');
        grid.style.display = 'grid';
        grid.innerHTML = themes.map(function(t, i) {
          var c = t.tokens && t.tokens.colors ? t.tokens.colors : {};
          var swatches = [c.primary, c.secondary, c.background, c.surface, c.text, c.textMuted, c.border]
            .map(function(col) { return '<div style="background:' + (col || '#ccc') + '"></div>'; }).join('');
          return '<div style="border-radius:6px;overflow:hidden;border:1px solid #dcdcde;background:#fff">'
            + '<div style="height:80px;display:grid;grid-template-columns:repeat(7,1fr)">' + swatches + '</div>'
            + '<div style="padding:14px">'
            + '<div style="font-weight:700;margin-bottom:2px">' + escHtml(t.name || 'Theme') + '</div>'
            + '<div style="font-size:12px;color:#646970;margin-bottom:12px">' + escHtml(t.description || '') + '</div>'
            + (t.author ? '<div style="font-size:11px;color:#646970;margin-bottom:12px">By ' + escHtml(t.author) + '</div>' : '')
            + '<button onclick="openBrowseInstall(' + i + ')" class="button button-small button-primary">Install</button>'
            + '</div></div>';
        }).join('');
        window._browseThemes = themes;
      })
      .catch(function() {
        document.getElementById('browse-loading').style.display = 'none';
        document.getElementById('browse-error').style.display = 'block';
      });
  }

  window.openBrowseInstall = function(idx) {
    var t = window._browseThemes[idx];
    if (!t) return;
    pendingBrowsePackage = t;
    document.getElementById('browse-install-title').textContent = 'Install "' + (t.name || 'Theme') + '"';
    var pages = t.pages || [];
    if (pages.length > 0) {
      document.getElementById('browse-pages-desc').textContent = 'Pages that will be created: ' + pages.map(function(p) { return p.title || p.slug; }).join(', ');
      document.getElementById('browse-install-pages-section').style.display = 'block';
    } else {
      document.getElementById('browse-install-pages-section').style.display = 'none';
    }
    document.getElementById('browse-install-status').style.display = 'none';
    document.getElementById('browse-install-modal').style.display = 'flex';
  };

  window.confirmBrowseInstall = function() {
    if (!pendingBrowsePackage) return;
    var createPages = document.getElementById('browse-create-pages-cb').checked;
    doInstall(pendingBrowsePackage, createPages, 'browse-install-btn', 'browse-install-status', function() {
      window.location.href = '/admin/themes';
    });
  };

  // ── Shared install ─────────────────────────────────────────────────────────
  function doInstall(pkg, createPages, btnId, statusId, onSuccess) {
    var btn = document.getElementById(btnId);
    var status = document.getElementById(statusId);
    btn.disabled = true;
    btn.textContent = 'Installing…';
    status.textContent = 'Installing theme…';
    status.style.display = 'block';

    fetch('/api/themes/import', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ package: pkg, createPages: createPages }),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok) {
          status.textContent = 'Installed! Redirecting…';
          setTimeout(onSuccess, 800);
        } else {
          status.style.color = '#d63638';
          status.textContent = data.error || 'Install failed';
          btn.disabled = false;
          btn.textContent = 'Install Theme';
        }
      })
      .catch(function() {
        status.style.color = '#d63638';
        status.textContent = 'Network error. Please try again.';
        btn.disabled = false;
        btn.textContent = 'Install Theme';
      });
  }

  function escHtml(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
})();
</script>
