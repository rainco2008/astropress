---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { wpOptions } from "@astropress/core/schema";
import { eq } from "drizzle-orm";
import { DEFAULT_THEME_TOKENS } from "@astropress/core/types/theme";
import type { Theme, ThemeTemplate } from "@astropress/core/types/theme";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

function uid() { return Math.random().toString(36).slice(2, 10) + Math.random().toString(36).slice(2, 10); }

// Load data
const [themesRow] = await db.select({ value: wpOptions.optionValue }).from(wpOptions).where(eq(wpOptions.optionName, "astropress_themes")).limit(1);
const [activeRow]  = await db.select({ value: wpOptions.optionValue }).from(wpOptions).where(eq(wpOptions.optionName, "astropress_active_theme")).limit(1);
const [siteUrlRow] = await db.select({ value: wpOptions.optionValue }).from(wpOptions).where(eq(wpOptions.optionName, "siteurl")).limit(1);

let themes: Theme[] = themesRow?.value ? JSON.parse(themesRow.value) : [];

// ── Bootstrap "Base Theme" + default templates if nothing exists ───────────
if (themes.length === 0) {
  const now = new Date().toISOString();

  const baseTheme: Theme = {
    id: "base-theme",
    name: "Base Theme",
    description: "A clean, minimal starter theme — edit to make it yours",
    version: "1.0.0",
    author: "AstroPress",
    tokens: DEFAULT_THEME_TOKENS,
    createdAt: now,
    updatedAt: now,
  };
  themes = [baseTheme];

  await db.insert(wpOptions)
    .values({ optionName: "astropress_themes", optionValue: JSON.stringify(themes), autoload: "yes" })
    .onConflictDoUpdate({ target: wpOptions.optionName, set: { optionValue: JSON.stringify(themes) } });
  await db.insert(wpOptions)
    .values({ optionName: "astropress_active_theme", optionValue: "base-theme", autoload: "yes" })
    .onConflictDoUpdate({ target: wpOptions.optionName, set: { optionValue: "base-theme" } });
  await db.insert(wpOptions)
    .values({ optionName: "astropress_theme_config", optionValue: JSON.stringify(DEFAULT_THEME_TOKENS), autoload: "yes" })
    .onConflictDoUpdate({ target: wpOptions.optionName, set: { optionValue: JSON.stringify(DEFAULT_THEME_TOKENS) } });

  // Seed header + footer templates
  const hId = uid(), fId = uid();
  const headerSlug = `__header_${hId}__`;
  const footerSlug = `__footer_${fId}__`;

  const seedTemplates: ThemeTemplate[] = [
    { id: hId, name: "Header 1", type: "header", conditions: [{ rule: "entire_site" }], schemaSlug: headerSlug, createdAt: now, updatedAt: now },
    { id: fId, name: "Footer 1", type: "footer", conditions: [{ rule: "entire_site" }], schemaSlug: footerSlug, createdAt: now, updatedAt: now },
  ];
  await db.insert(wpOptions)
    .values({ optionName: "astropress_theme_templates", optionValue: JSON.stringify(seedTemplates), autoload: "yes" })
    .onConflictDoUpdate({ target: wpOptions.optionName, set: { optionValue: JSON.stringify(seedTemplates) } });

  const headerSchema = {
    version: 1,
    blocks: [{
      id: uid(), type: "nav",
      props: {
        logo: "AstroPress", logoSize: 22, sticky: false,
        links: [
          { label: "Home", url: "/" },
          { label: "Blog", url: "/blog" },
          { label: "About", url: "/about" },
          { label: "Contact", url: "/contact" },
        ],
        align: "right", background: "#ffffff", textColor: "#1d2327", borderBottom: true,
      },
    }],
  };
  await db.insert(wpOptions).values({
    optionName: `astropress_page_schema_${headerSlug}`,
    optionValue: JSON.stringify(headerSchema),
    autoload: "no",
  });

  const footerSchema = {
    version: 1,
    blocks: [{
      id: uid(), type: "html",
      props: {
        html: `<footer style="background:#1d2327;color:#a7aaad;padding:48px 24px;text-align:center"><div style="max-width:1200px;margin:0 auto"><div style="display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:24px"><a href="/" style="color:#a7aaad;text-decoration:none">Home</a><a href="/blog" style="color:#a7aaad;text-decoration:none">Blog</a><a href="/about" style="color:#a7aaad;text-decoration:none">About</a><a href="/contact" style="color:#a7aaad;text-decoration:none">Contact</a></div><p style="margin:0;font-size:13px">© ${new Date().getFullYear()} Your Site. Built with AstroPress.</p></div></footer>`,
      },
    }],
  };
  await db.insert(wpOptions).values({
    optionName: `astropress_page_schema_${footerSlug}`,
    optionValue: JSON.stringify(footerSchema),
    autoload: "no",
  });
}

const activeThemeId = activeRow?.value ?? themes[0]?.id ?? "base-theme";
const siteUrl = siteUrlRow?.value ?? "http://localhost:4322";
---
<AdminLayout title="Themes">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
    <h1 class="wp-heading-inline" style="margin:0">Themes</h1>
    <div style="display:flex;gap:8px">
      <a href="/admin/themes/builder" class="button">Theme Builder</a>
      <button onclick="document.getElementById('new-theme-modal').style.display='flex'" class="button button-primary">Add New Theme</button>
    </div>
  </div>
  <hr class="wp-header-end" />

  <!-- Theme Gallery -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-bottom:40px">
    {themes.map((theme) => {
      const isActive = theme.id === activeThemeId;
      const c = theme.tokens.colors;
      return (
        <div data-theme-id={theme.id} style={`border-radius:6px;overflow:hidden;border:${isActive ? "3px solid #2271b1" : "1px solid #dcdcde"};background:#fff;position:relative`}>
          {isActive && (
            <div style="position:absolute;top:10px;left:10px;background:#2271b1;color:#fff;font-size:11px;font-weight:700;padding:2px 10px;border-radius:99px;letter-spacing:0.3px;z-index:1">Active</div>
          )}
          <!-- Color swatch preview -->
          <div style="height:120px;display:grid;grid-template-columns:repeat(7,1fr);gap:0">
            {[c.primary, c.secondary, c.background, c.surface, c.text, c.textMuted, c.border].map((color) => (
              <div style={`background:${color}`}></div>
            ))}
          </div>
          <!-- Font preview -->
          <div style={`padding:12px 14px;background:${c.background};border-bottom:1px solid ${c.border}`}>
            <div style={`font-family:${theme.tokens.fonts.heading};font-size:15px;font-weight:700;color:${c.text}`}>{theme.name}</div>
            <div style={`font-family:${theme.tokens.fonts.body};font-size:12px;color:${c.textMuted};margin-top:2px`}>{theme.description || "No description"}</div>
          </div>
          <!-- Actions -->
          <div style="padding:10px 14px;background:#f6f7f7;display:flex;gap:6px;flex-wrap:wrap">
            <a href="/admin/themes/builder" class="button button-small button-primary">Customize</a>
            {!isActive && (
              <button onclick={`activateTheme('${theme.id}')`} class="button button-small">Activate</button>
            )}
            <a href={`/api/themes/export/${theme.id}`} download class="button button-small" title="Export theme as JSON">Export</a>
            {!isActive && (
              <button onclick={`deleteTheme('${theme.id}')`} class="button button-small" style="color:#d63638;border-color:#d63638;margin-left:auto">Delete</button>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- New Theme Modal -->
  <div id="new-theme-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;z-index:9999">
    <div style="background:#fff;border-radius:6px;padding:28px;width:440px;max-width:90vw">
      <h2 style="margin:0 0 20px;font-size:18px">Create New Theme</h2>
      <div style="margin-bottom:14px">
        <label class="wp-form-label">Theme Name</label>
        <input id="new-theme-name" type="text" class="wp-input" style="width:100%" placeholder="My Custom Theme" />
      </div>
      <div style="margin-bottom:14px">
        <label class="wp-form-label">Description</label>
        <input id="new-theme-desc" type="text" class="wp-input" style="width:100%" placeholder="Optional description" />
      </div>
      <div style="margin-bottom:20px">
        <label class="wp-form-label">Start from</label>
        <select id="new-theme-clone" class="wp-input" style="width:100%">
          <option value="">Blank (default tokens)</option>
          {themes.map(t => <option value={t.id}>{t.name}</option>)}
        </select>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button onclick="document.getElementById('new-theme-modal').style.display='none'" class="button">Cancel</button>
        <button onclick="createTheme()" class="button button-primary">Create Theme</button>
      </div>
    </div>
  </div>


</AdminLayout>

<script is:inline>
  (function () {
    window.activateTheme = async function (id) {
      if (!confirm('Activate this theme? It will apply to your live site immediately.')) return;
      const res = await fetch('/api/themes/' + id, { method: 'POST' });
      if (res.ok) location.reload();
      else alert('Failed to activate theme');
    };

    window.deleteTheme = async function (id) {
      if (!confirm('Delete this theme? This cannot be undone.')) return;
      const res = await fetch('/api/themes/' + id, { method: 'DELETE' });
      if (res.ok) location.reload();
      else {
        const data = await res.json();
        alert(data.error || 'Failed to delete theme');
      }
    };

    window.createTheme = async function () {
      const name = document.getElementById('new-theme-name').value.trim();
      if (!name) { alert('Theme name is required'); return; }
      const desc = document.getElementById('new-theme-desc').value.trim();
      const cloneId = document.getElementById('new-theme-clone').value;

      let cloneFrom = null;
      if (cloneId) {
        const res = await fetch('/api/themes');
        const data = await res.json();
        const src = data.themes?.find(function(t) { return t.id === cloneId; });
        if (src) cloneFrom = src.tokens;
      }

      const res = await fetch('/api/themes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, description: desc, cloneFrom: cloneFrom }),
      });
      const data = await res.json();
      if (res.ok && data.theme) {
        window.location.href = '/admin/themes/customize/' + data.theme.id;
      } else {
        alert('Failed to create theme');
      }
    };

  })();
</script>
