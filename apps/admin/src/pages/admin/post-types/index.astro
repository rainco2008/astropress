---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { adminIcons, ICON_NAMES, getIcon } from "../../../lib/icons";
import { wpOptions } from "@astropress/core/schema";
import { eq } from "drizzle-orm";

const db = Astro.locals.db;
if (!db || !Astro.locals.user) return Astro.redirect("/login");

const editing = Astro.url.searchParams.get("edit");
const isNew = Astro.url.searchParams.get("new") === "1";

// Read directly from DB — avoids registry staleness
const [row] = await db.select({ value: wpOptions.optionValue }).from(wpOptions).where(eq(wpOptions.optionName, "astropress_custom_post_types")).limit(1);
const rawTypes: any[] = row?.value ? JSON.parse(row.value) : [];

// Normalise: support both flat { key, label, pluralLabel } and nested { key, config: {...} }
const customTypes = rawTypes.map((t: any) => ({
  slug: t.key,
  config: t.config ? { ...t.config } : {
    label: t.label ?? t.key,
    pluralLabel: t.pluralLabel ?? t.key,
    description: t.description ?? "",
    icon: t.icon ?? "folder",
    showInMenu: t.showInMenu ?? true,
    supports: t.supports ?? ["title","editor","excerpt"],
    custom: true,
  },
}));

const editingType = editing ? customTypes.find(t => t.slug === editing) : null;

const SUPPORTS = ["title","editor","excerpt","thumbnail","custom-fields","author","comments","revisions"] as const;

// Icons available in the post-type picker (exclude system-only icons)
const PICKER_ICONS = ICON_NAMES.filter(n =>
  !["bolt","logout","user"].includes(n)
);
---

<AdminLayout title="Post Types">
  <div style="display:grid;grid-template-columns:280px 1fr;gap:0;min-height:calc(100vh - 32px);margin:-20px -20px -40px">

    <!-- Left: list -->
    <div style="background:#fff;border-right:1px solid #dcdcde;display:flex;flex-direction:column">
      <div style="padding:16px 20px;border-bottom:1px solid #dcdcde;display:flex;align-items:center;justify-content:space-between">
        <span style="font-size:13px;font-weight:700;color:#1d2327;text-transform:uppercase;letter-spacing:.5px">Post Types</span>
        <a href="?new=1" style="font-size:12px;background:#2271b1;color:#fff;padding:4px 10px;border-radius:3px;text-decoration:none;font-weight:600">+ Add New</a>
      </div>

      <div style="flex:1;overflow-y:auto">
        {customTypes.length === 0 && !isNew && (
          <div style="padding:32px 20px;text-align:center;color:#646970;font-size:13px">
            No post types yet.<br/>
            <a href="?new=1" style="color:#2271b1;font-size:12px;margin-top:8px;display:inline-block">Create your first →</a>
          </div>
        )}

        {customTypes.map(pt => (
          <a
            href={`?edit=${pt.slug}`}
            style={`display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid #f0f0f1;text-decoration:none;transition:background 0.1s;${editing === pt.slug ? "background:#f0f6fc;border-left:3px solid #2271b1;" : "border-left:3px solid transparent;"}`}
          >
            <span style={`width:28px;text-align:center;color:${editing === pt.slug ? "#2271b1" : "#646970"};display:flex;align-items:center;justify-content:center`}>
              <Fragment set:html={getIcon(pt.config.icon ?? "folder")} />
            </span>
            <div style="min-width:0">
              <div style="font-size:13px;font-weight:600;color:#1d2327">{pt.config.pluralLabel}</div>
              <div style="font-size:11px;color:#646970;font-family:monospace">{pt.slug}</div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: form -->
    <div style="background:#f6f7f7;padding:32px">

      {!isNew && !editingType && (
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:300px;color:#646970;text-align:center">
          <div style="margin-bottom:16px;opacity:0.3;transform:scale(2.5);transform-origin:center">
            <Fragment set:html={adminIcons.posttypes} />
          </div>
          <h2 style="font-size:16px;font-weight:600;margin:0 0 8px;color:#1d2327">Manage Post Types</h2>
          <p style="font-size:13px;margin:0 0 16px">Create custom post types to organise your content.</p>
          <a href="?new=1" style="background:#2271b1;color:#fff;padding:8px 18px;border-radius:3px;text-decoration:none;font-size:13px;font-weight:600">Add Post Type</a>
        </div>
      )}

      {(isNew || editingType) && (
        <div style="max-width:720px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
            <h1 style="margin:0;font-size:20px;font-weight:700;color:#1d2327">{isNew ? "Add New Post Type" : `Edit: ${editingType!.config.pluralLabel}`}</h1>
            {editingType && (
              <button
                id="delete-btn"
                data-key={editingType.slug}
                style="font-size:12px;color:#d63638;background:#fff;border:1px solid #d63638;padding:6px 12px;border-radius:3px;cursor:pointer"
              >
                Delete Post Type
              </button>
            )}
          </div>

          <form id="pt-form">
            <!-- Basic Settings -->
            <div style="background:#fff;border:1px solid #dcdcde;border-radius:4px;margin-bottom:16px;overflow:hidden">
              <div style="padding:14px 20px;background:#f6f7f7;border-bottom:1px solid #dcdcde;font-size:13px;font-weight:700;color:#1d2327">Basic Settings</div>
              <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px">

                <div>
                  <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px;color:#1d2327">Singular Label <span style="color:#d63638">*</span></label>
                  <input name="label" required value={editingType?.config.label ?? ""}
                    placeholder="e.g. Book"
                    style="width:100%;padding:8px 10px;font-size:13px;border:1px solid #8c8f94;border-radius:3px;outline:none"
                    oninput="autoKey(this)" />
                  <p style="font-size:11px;color:#646970;margin:4px 0 0">The singular name for this post type.</p>
                </div>

                <div>
                  <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px;color:#1d2327">Plural Label <span style="color:#d63638">*</span></label>
                  <input name="pluralLabel" required value={editingType?.config.pluralLabel ?? ""}
                    placeholder="e.g. Books"
                    style="width:100%;padding:8px 10px;font-size:13px;border:1px solid #8c8f94;border-radius:3px;outline:none" />
                </div>

                <div>
                  <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px;color:#1d2327">Post Type Key <span style="color:#d63638">*</span></label>
                  <input name="key" id="pt-key" required value={editingType?.slug ?? ""}
                    placeholder="e.g. book"
                    readonly={!!editingType}
                    style={`width:100%;padding:8px 10px;font-size:13px;font-family:monospace;border:1px solid #8c8f94;border-radius:3px;outline:none;${editingType ? "background:#f6f7f7;color:#646970;" : ""}`} />
                  <p style="font-size:11px;color:#646970;margin:4px 0 0">Lowercase, no spaces. Max 20 chars.</p>
                </div>

                <div style="grid-column:1/-1">
                  <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px;color:#1d2327">Icon</label>
                  <div style="display:flex;gap:4px;flex-wrap:wrap;max-height:148px;overflow-y:auto;padding:4px;background:#f6f7f7;border:1px solid #dcdcde;border-radius:3px">
                    {PICKER_ICONS.map(name => {
                      const active = editingType
                        ? editingType.config.icon === name
                        : name === "post";
                      return (
                        <label title={name} style="cursor:pointer">
                          <input type="radio" name="icon" value={name} style="display:none" checked={active} />
                          <span
                            class="icon-opt"
                            style={`display:flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:4px;border:2px solid transparent;cursor:pointer;color:#646970;transition:all 0.1s;${active ? "border-color:#2271b1;background:#fff;color:#2271b1;" : ""}`}
                          >
                            <Fragment set:html={adminIcons[name]} />
                          </span>
                        </label>
                      );
                    })}
                  </div>
                  <p style="font-size:11px;color:#646970;margin:4px 0 0">Hover an icon to see its name.</p>
                </div>

                <div style="grid-column:1/-1">
                  <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px;color:#1d2327">Description</label>
                  <textarea name="description" rows="2"
                    placeholder="Optional description"
                    style="width:100%;padding:8px 10px;font-size:13px;border:1px solid #8c8f94;border-radius:3px;outline:none;resize:vertical"
                  >{editingType?.config.description ?? ""}</textarea>
                </div>
              </div>
            </div>

            <!-- Settings -->
            <div style="background:#fff;border:1px solid #dcdcde;border-radius:4px;margin-bottom:16px;overflow:hidden">
              <div style="padding:14px 20px;background:#f6f7f7;border-bottom:1px solid #dcdcde;font-size:13px;font-weight:700;color:#1d2327">Settings</div>
              <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:12px">
                {[
                  { name: "public",             label: "Public",               desc: "Visible to users and in queries",            default: true },
                  { name: "showInRest",         label: "Show in REST API",     desc: "Enables block editor support",               default: true },
                  { name: "hierarchical",       label: "Hierarchical",         desc: "Like pages (parent/child)",                  default: false },
                  { name: "hasArchive",         label: "Has Archive",          desc: "Enables archive page",                      default: false },
                  { name: "excludeFromSearch",  label: "Exclude from Search",  desc: "Hide from search results",                  default: false },
                ].map(field => {
                  const val = editingType ? (editingType.config as any)[field.name] : field.default;
                  return (
                    <label style="display:flex;gap:10px;align-items:flex-start;cursor:pointer;padding:6px 0">
                      <input type="checkbox" name={field.name} value="1"
                        checked={val === true || val === undefined && field.default}
                        style="margin-top:2px;width:15px;height:15px;flex-shrink:0" />
                      <span>
                        <span style="font-size:13px;font-weight:600;color:#1d2327;display:block">{field.label}</span>
                        <span style="font-size:11px;color:#646970">{field.desc}</span>
                      </span>
                    </label>
                  );
                })}
              </div>
            </div>

            <!-- Supports -->
            <div style="background:#fff;border:1px solid #dcdcde;border-radius:4px;margin-bottom:16px;overflow:hidden">
              <div style="padding:14px 20px;background:#f6f7f7;border-bottom:1px solid #dcdcde;font-size:13px;font-weight:700;color:#1d2327">Supports</div>
              <div style="padding:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px">
                {SUPPORTS.map(s => {
                  const checked = editingType
                    ? editingType.config.supports?.includes(s as any) ?? false
                    : ["title","editor","excerpt","thumbnail","custom-fields"].includes(s);
                  return (
                    <label style="display:flex;gap:8px;align-items:center;cursor:pointer;font-size:13px;color:#1d2327">
                      <input type="checkbox" name="supports" value={s} checked={checked}
                        style="width:14px;height:14px" />
                      {s}
                    </label>
                  );
                })}
              </div>
            </div>

            <div style="display:flex;gap:10px;align-items:center">
              <button type="submit" style="background:#2271b1;color:#fff;padding:9px 20px;border:none;border-radius:3px;font-size:14px;font-weight:600;cursor:pointer">
                {isNew ? "Create Post Type" : "Update Post Type"}
              </button>
              <a href="/admin/post-types" style="font-size:13px;color:#646970;text-decoration:none">Cancel</a>
              <span id="pt-status" style="font-size:13px;color:#646970;margin-left:8px"></span>
            </div>
          </form>
        </div>
      )}
    </div>
  </div>

  <style>
    input[type="radio"]:checked + .icon-opt { border-color: #2271b1 !important; background: #fff !important; color: #2271b1 !important; }
    .icon-opt:hover { background: #fff !important; color: #2271b1 !important; }
    input:focus { border-color: #2271b1 !important; box-shadow: 0 0 0 1px #2271b1; }
  </style>

  <script is:inline>
    // Auto-generate key from singular label
    function autoKey(input) {
      var keyEl = document.getElementById("pt-key");
      if (keyEl && !keyEl.readOnly) {
        keyEl.value = input.value.toLowerCase().trim()
          .replace(/[^a-z0-9]+/g, "_")
          .replace(/^_+|_+$/g, "")
          .slice(0, 20);
      }
    }

    // Handle form submit
    var form = document.getElementById("pt-form");
    if (form) {
      form.addEventListener("submit", async function(e) {
        e.preventDefault();
        var status = document.getElementById("pt-status");
        status.textContent = "Saving…";

        var fd = new FormData(form);
        var supports = fd.getAll("supports");
        var payload = {
          key: fd.get("key"),
          label: fd.get("label"),
          pluralLabel: fd.get("pluralLabel"),
          description: fd.get("description") || undefined,
          icon: fd.get("icon") || "post",
          public: fd.get("public") === "1",
          showInRest: fd.get("showInRest") === "1",
          hierarchical: fd.get("hierarchical") === "1",
          hasArchive: fd.get("hasArchive") === "1",
          excludeFromSearch: fd.get("excludeFromSearch") === "1",
          supports: supports,
        };

        var res = await fetch("/api/post-types", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          status.textContent = "Saved ✓";
          setTimeout(function() { location.href = "/admin/post-types?edit=" + payload.key; }, 600);
        } else {
          status.textContent = "Error saving";
        }
      });
    }

    // Handle delete
    var deleteBtn = document.getElementById("delete-btn");
    if (deleteBtn) {
      deleteBtn.addEventListener("click", async function() {
        if (!confirm("Delete this post type? This cannot be undone.")) return;
        var key = deleteBtn.dataset.key;
        var res = await fetch("/api/post-types/" + key, { method: "DELETE" });
        if (res.ok) location.href = "/admin/post-types";
      });
    }

    // Icon radio highlight on change
    document.querySelectorAll("input[name='icon']").forEach(function(radio) {
      radio.addEventListener("change", function() {
        document.querySelectorAll(".icon-opt").forEach(function(el) {
          el.style.borderColor = "transparent";
          el.style.background = "";
        });
        if (radio.checked) {
          var opt = radio.nextElementSibling;
          opt.style.borderColor = "#2271b1";
          opt.style.background = "#f0f6fc";
        }
      });
    });
  </script>
</AdminLayout>
