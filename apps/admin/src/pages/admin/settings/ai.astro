---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { eq } from "drizzle-orm";
import { wpOptions } from "@astropress/core/schema";
import AISettings from "../../../islands/AISettings";

const db = Astro.locals.db;
if (!db || !Astro.locals.user) return Astro.redirect("/login");

// Check if any AI provider is already configured
const row = await db
  .select()
  .from(wpOptions)
  .where(eq(wpOptions.optionName, "astropress_ai_settings"))
  .get();

let isConfigured = false;
let activeProvider = "";

if (row?.optionValue) {
  try {
    const s = JSON.parse(row.optionValue);
    activeProvider = s.activeProvider ?? "";
    const providers = s.providers ?? {};
    isConfigured = Object.values(providers).some(
      (p: any) => p?.apiKey && p.enabled !== false
    );
  } catch {}
}
---
<AdminLayout title="Settings › AI">
  <div class="settings-wrap">

    <!-- Page heading -->
    <h1 class="wp-page-title">Settings</h1>

    <!-- Sub-nav tabs -->
    <nav class="nav-tab-wrapper">
      <a href="/admin/settings" class="nav-tab">General</a>
      <a href="/admin/settings/ai" class="nav-tab nav-tab-active">AI</a>
    </nav>

    {!isConfigured ? (
      <!-- Setup required state -->
      <div class="ai-setup-required">
        <div class="ai-setup-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="color:#2271b1">
            <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
          </svg>
        </div>
        <h2 class="ai-setup-heading">Set up AI for AstroPress</h2>
        <p class="ai-setup-desc">
          Connect an AI provider to unlock the AI assistant — write content, generate titles,
          fill in excerpts, and manage your site using natural language.
        </p>
        <div class="ai-setup-providers">
          <span class="ai-provider-chip">Claude (Anthropic)</span>
          <span class="ai-provider-chip">GPT (OpenAI)</span>
          <span class="ai-provider-chip">Gemini (Google)</span>
          <span class="ai-provider-chip">Mistral</span>
          <span class="ai-provider-chip">Groq</span>
        </div>
        <p class="ai-setup-hint">
          Paste any API key below to get started. Keys are stored securely in your database and never exposed publicly.
        </p>
      </div>
    ) : (
      <div class="notice notice-success" style="margin-bottom:20px;max-width:640px">
        AI is active — using <strong>{activeProvider}</strong>. The assistant is available on every admin page.
      </div>
    )}

    <!-- AISettings island always rendered so user can edit/switch -->
    <AISettings client:only="react" />

  </div>
</AdminLayout>

<style is:global>
  .settings-wrap { max-width: 860px; }

  /* ── Setup required state ───────────────────────────────────────────── */
  .ai-setup-required {
    max-width: 540px;
    background: var(--wp-white);
    border: 1px solid var(--wp-gray-300);
    border-top: 4px solid var(--wp-blue);
    padding: 32px 32px 28px;
    margin-bottom: 28px;
    text-align: center;
  }
  .ai-setup-icon { margin-bottom: 16px; }
  .ai-setup-heading {
    font-size: 18px; font-weight: 600;
    margin: 0 0 10px; color: var(--wp-gray-900);
  }
  .ai-setup-desc {
    font-size: 13px; color: var(--wp-gray-600);
    margin: 0 0 16px; line-height: 1.6;
  }
  .ai-setup-providers {
    display: flex; flex-wrap: wrap; gap: 6px;
    justify-content: center; margin-bottom: 16px;
  }
  .ai-provider-chip {
    display: inline-block;
    padding: 3px 10px;
    background: var(--wp-blue-light);
    color: var(--wp-blue);
    border: 1px solid #c5d9f0;
    border-radius: 12px;
    font-size: 11px; font-weight: 600;
  }
  .ai-setup-hint {
    font-size: 11px; color: var(--wp-gray-500);
    margin: 0; line-height: 1.5;
  }
</style>
