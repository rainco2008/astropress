---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { eq } from "drizzle-orm";
import { wpOptions } from "@astropress/core/schema";

const db = Astro.locals.db;

// Handle POST (save settings)
if (Astro.request.method === "POST") {
  const body = await Astro.request.text();
  const form = new URLSearchParams(body);
  const updates: Record<string, string> = {
    blogname: form.get("blogname")?.trim() ?? "",
    blogdescription: form.get("blogdescription")?.trim() ?? "",
    siteurl: form.get("siteurl")?.trim() ?? "",
    admin_email: form.get("admin_email")?.trim() ?? "",
    posts_per_page: form.get("posts_per_page")?.trim() ?? "10",
  };

  if (db) {
    for (const [key, value] of Object.entries(updates)) {
      await db
        .insert(wpOptions)
        .values({ optionName: key, optionValue: value })
        .onConflictDoUpdate({
          target: wpOptions.optionName,
          set: { optionValue: value },
        });
    }
  }

  return Astro.redirect("/admin/settings?saved=1");
}

const saved = Astro.url.searchParams.get("saved") === "1";

// Load current options
let opts: Record<string, string> = {};
if (db) {
  const rows = await db
    .select({ name: wpOptions.optionName, value: wpOptions.optionValue })
    .from(wpOptions);
  opts = Object.fromEntries(rows.map((r) => [r.name, r.value]));
}
---
<AdminLayout title="Settings">
  <h1 style="margin:0 0 24px;font-size:22px;font-weight:600">Settings</h1>

  {saved && (
    <div style="background:#d1e7dd;border-left:4px solid #146c43;color:#146c43;padding:10px 14px;border-radius:3px;margin-bottom:20px;font-size:13px">
      Settings saved successfully.
    </div>
  )}

  <form method="POST">
    <div style="background:#fff;border:1px solid #dcdcde;border-radius:4px;overflow:hidden;margin-bottom:20px">
      <div style="background:#f6f7f7;padding:10px 16px;font-size:13px;font-weight:600;border-bottom:1px solid #dcdcde">General</div>
      <div style="padding:20px;display:grid;gap:16px">

        <div>
          <label style="font-size:13px;font-weight:600;display:block;margin-bottom:5px">Site Title</label>
          <input name="blogname" type="text" value={opts.blogname ?? ""} style="width:100%;max-width:480px;padding:8px 10px;font-size:14px;border:1px solid #8c8f94;border-radius:3px" />
        </div>

        <div>
          <label style="font-size:13px;font-weight:600;display:block;margin-bottom:5px">Tagline</label>
          <input name="blogdescription" type="text" value={opts.blogdescription ?? ""} style="width:100%;max-width:480px;padding:8px 10px;font-size:14px;border:1px solid #8c8f94;border-radius:3px" />
          <p style="font-size:11px;color:#646970;margin:4px 0 0">In a few words, explain what this site is about.</p>
        </div>

        <div>
          <label style="font-size:13px;font-weight:600;display:block;margin-bottom:5px">Site URL</label>
          <input name="siteurl" type="url" value={opts.siteurl ?? ""} style="width:100%;max-width:480px;padding:8px 10px;font-size:14px;border:1px solid #8c8f94;border-radius:3px" />
        </div>

        <div>
          <label style="font-size:13px;font-weight:600;display:block;margin-bottom:5px">Admin Email</label>
          <input name="admin_email" type="email" value={opts.admin_email ?? ""} style="width:100%;max-width:480px;padding:8px 10px;font-size:14px;border:1px solid #8c8f94;border-radius:3px" />
        </div>

        <div>
          <label style="font-size:13px;font-weight:600;display:block;margin-bottom:5px">Posts Per Page</label>
          <input name="posts_per_page" type="number" min="1" max="100" value={opts.posts_per_page ?? "10"} style="width:80px;padding:8px 10px;font-size:14px;border:1px solid #8c8f94;border-radius:3px" />
        </div>

      </div>
    </div>

    <button type="submit" style="padding:9px 20px;background:#2271b1;color:#fff;border:none;border-radius:3px;font-size:14px;font-weight:600;cursor:pointer">
      Save Changes
    </button>
  </form>
</AdminLayout>
