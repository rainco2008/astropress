---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listPosts } from "../../../lib/posts";

const db = Astro.locals.db;
if (!Astro.locals.user || !db) return Astro.redirect("/login");

const status = Astro.url.searchParams.get("status") ?? undefined;
const page = Number(Astro.url.searchParams.get("page") ?? "1");

const { posts, total } = await listPosts(db, { type: "page", status, page });

const perPage = 20;
const totalPages = Math.ceil(total / perPage);
const isTrash = status === "trash";

const statusOptions = [
  { value: "", label: "All" },
  { value: "publish", label: "Published" },
  { value: "draft", label: "Draft" },
  { value: "trash", label: "Trash" },
];
---
<AdminLayout title="Pages">

  <h1 class="wp-heading-inline">Pages</h1>
  <a href="/admin/pages/new" class="page-title-action">Add New</a>
  <hr class="wp-header-end" />

  <ul class="subsubsub">
    {statusOptions.map((s) => (
      <li>
        <a
          href={s.value ? `/admin/pages?status=${s.value}` : "/admin/pages"}
          class={(status ?? "") === s.value ? "current" : ""}
        >
          {s.label}
        </a>
      </li>
    ))}
  </ul>

  {posts.length === 0 ? (
    <div class="ap-empty-state">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" style="color:#8c8f94;margin-bottom:12px">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      <h2 style="font-size:15px;font-weight:600;color:#1d2327;margin:0 0 8px">No Pages Yet</h2>
      <p style="font-size:13px;color:#646970;margin:0 0 20px;line-height:1.5">
        {status ? `No pages with status "${status}".` : "Create pages for your site like About, Contact, or a Home page."}
      </p>
      <a href="/admin/pages/new" class="button button-primary">Add Your First Page</a>
    </div>
  ) : (
    <form id="bulk-action-form">
      <!-- Top tablenav -->
      <div class="tablenav top">
        <div class="alignleft actions bulkactions">
          <select class="bulk-action-selector" id="bulk-action-selector-top">
            <option value="-1">Bulk actions</option>
            {isTrash ? (
              <>
                <option value="restore">Restore</option>
                <option value="delete">Delete Permanently</option>
              </>
            ) : (
              <>
                <option value="trash">Move to Trash</option>
                <option value="publish">Publish</option>
                <option value="draft">Move to Draft</option>
              </>
            )}
          </select>
          <button type="button" onclick="applyBulkAction()" class="button action">Apply</button>
        </div>
        <div class="tablenav-pages" style="line-height:28px">
          <span class="displaying-num">{total} item{total !== 1 ? "s" : ""}</span>
        </div>
      </div>

      <table class="wp-list-table widefat fixed striped">
        <thead>
          <tr>
            <th scope="col" class="manage-column column-cb check-column" style="width:2.2em">
              <input type="checkbox" id="cb-select-all-1" title="Select all" />
            </th>
            <th scope="col" class="manage-column column-primary">Title</th>
            <th scope="col" class="manage-column" style="width:100px">Status</th>
            <th scope="col" class="manage-column" style="width:120px">Date</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((p) => (
            <tr>
              <th scope="row" class="check-column">
                <input type="checkbox" class="cb-select-posts" value={String(p.id)} />
              </th>
              <td class="title column-title has-row-actions column-primary">
                <strong>
                  <a href={`/admin/pages/${p.id}`} class="row-title">
                    {p.title || <em style="font-weight:400;color:#8c8f94">Untitled</em>}
                  </a>
                </strong>
                <div style="font-size:11px;color:#8c8f94;font-family:monospace;margin-top:2px">/{p.slug}</div>
                <div class="row-actions">
                  {!isTrash && <span class="edit"><a href={`/admin/pages/${p.id}`}>Edit</a> | </span>}
                  {!isTrash && <span class="view"><a href={`/${p.slug}`} target="_blank" rel="noopener">View</a> | </span>}
                  {!isTrash && (
                    <span class="trash">
                      <button onclick={`apBulkSingle('trash',${p.id})`} class="ap-row-delete-btn">Trash</button>
                    </span>
                  )}
                  {isTrash && (
                    <>
                      <span class="untrash"><button onclick={`apBulkSingle('restore',${p.id})`} class="ap-row-delete-btn" style="color:#2271b1">Restore</button> | </span>
                      <span class="delete"><button onclick={`apBulkSingle('delete',${p.id})`} class="ap-row-delete-btn">Delete Permanently</button></span>
                    </>
                  )}
                </div>
              </td>
              <td>
                <span style={`display:inline-block;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:600;background:${p.status === "publish" ? "#d1e7dd" : p.status === "trash" ? "#f8d7da" : "#fff3cd"};color:${p.status === "publish" ? "#146c43" : p.status === "trash" ? "#842029" : "#997404"}`}>
                  {p.status === "publish" ? "Published" : p.status.charAt(0).toUpperCase() + p.status.slice(1)}
                </span>
              </td>
              <td style="color:var(--wp-gray-600);font-size:12px">{p.date.slice(0, 10)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <!-- Bottom tablenav -->
      <div class="tablenav bottom">
        <div class="alignleft actions bulkactions">
          <select class="bulk-action-selector" id="bulk-action-selector-bottom">
            <option value="-1">Bulk actions</option>
            {isTrash ? (
              <>
                <option value="restore">Restore</option>
                <option value="delete">Delete Permanently</option>
              </>
            ) : (
              <>
                <option value="trash">Move to Trash</option>
                <option value="publish">Publish</option>
                <option value="draft">Move to Draft</option>
              </>
            )}
          </select>
          <button type="button" onclick="applyBulkAction()" class="button action">Apply</button>
        </div>
        {totalPages > 1 && (
          <div class="tablenav-pages">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
              <a
                href={`/admin/pages?page=${p}${status ? `&status=${status}` : ""}`}
                class={p === page ? "button button-disabled" : "button"}
                style={p === page ? "font-weight:700" : ""}
              >
                {p}
              </a>
            ))}
          </div>
        )}
      </div>
    </form>
  )}

</AdminLayout>

<script is:inline>
window.apBulkActions = window.apBulkActions || [];

(function () {
  document.querySelectorAll('.bulk-action-selector').forEach(function (sel) {
    sel.addEventListener('change', function () {
      document.querySelectorAll('.bulk-action-selector').forEach(function (s) { s.value = sel.value; });
    });
  });
  var selectAll = document.getElementById('cb-select-all-1');
  if (selectAll) {
    selectAll.addEventListener('change', function () {
      document.querySelectorAll('.cb-select-posts').forEach(function (cb) { cb.checked = selectAll.checked; });
    });
  }
  document.querySelectorAll('.cb-select-posts').forEach(function (cb) {
    cb.addEventListener('change', function () {
      if (selectAll) selectAll.checked = document.querySelectorAll('.cb-select-posts:not(:checked)').length === 0;
    });
  });
})();

window.applyBulkAction = async function () {
  var sel = document.querySelector('.bulk-action-selector');
  var action = sel ? sel.value : '-1';
  if (!action || action === '-1') { alert('Please select an action.'); return; }
  var ids = Array.from(document.querySelectorAll('.cb-select-posts:checked')).map(function (cb) { return parseInt(cb.value); });
  if (ids.length === 0) { alert('Please select at least one item.'); return; }
  var custom = (window.apBulkActions || []).find(function (a) { return a.value === action && a.handler; });
  if (custom) { return custom.handler(ids); }
  var confirmMsg = action === 'delete' ? 'Permanently delete ' + ids.length + ' item(s)? This cannot be undone.' : 'Apply to ' + ids.length + ' item(s)?';
  if (!confirm(confirmMsg)) return;
  var res = await fetch('/api/posts/bulk', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: action, ids: ids }) });
  if (res.ok) { location.reload(); }
  else { var d = await res.json().catch(function () { return {}; }); alert(d.error || 'Action failed.'); }
};

window.apBulkSingle = async function (action, id) {
  var confirmMsg = action === 'delete' ? 'Permanently delete this item? This cannot be undone.' : action === 'trash' ? 'Move to trash?' : null;
  if (confirmMsg && !confirm(confirmMsg)) return;
  var res = await fetch('/api/posts/bulk', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: action, ids: [id] }) });
  if (res.ok) { location.reload(); }
  else { var d = await res.json().catch(function () { return {}; }); alert(d.error || 'Action failed.'); }
};
</script>
