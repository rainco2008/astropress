---
import { getPostTypes } from "@astropress/core/registry";

interface Props {
  title?: string;
  activeSlug?: string;
}

const { title = "AstroPress Admin", activeSlug } = Astro.props;
const user = Astro.locals.user;
const currentPath = new URL(Astro.request.url).pathname;

const postTypes = getPostTypes().filter((pt) => pt.config.showInMenu);

// ── Flat SVG icons (16×16, stroke, currentColor) ──────────────────────────
const icons: Record<string, string> = {
  dashboard: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  post:       `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  page:       `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>`,
  folder:     `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
  forms:      `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>`,
  fields:     `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>`,
  posttypes:  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  taxonomies: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
  plugins:    `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>`,
  menus:      `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>`,
  settings:   `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  user:       `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  bolt:       `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  logout:     `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>`,
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; font-family: system-ui, -apple-system, sans-serif; background: #f6f7f7; color: #1d2327; }
      .layout { display: flex; min-height: 100vh; }

      /* Sidebar */
      .sidebar { width: 220px; background: #1d2327; color: #a7aaad; flex-shrink: 0; display: flex; flex-direction: column; }
      .sidebar-brand {
        padding: 14px 20px; font-size: 15px; font-weight: 700; color: #fff;
        border-bottom: 1px solid #2c3338; letter-spacing: -0.2px;
        display: flex; align-items: center; gap: 8px;
      }
      .sidebar-brand svg { opacity: 0.9; flex-shrink: 0; }
      .sidebar-nav { padding: 8px 0; flex: 1; overflow-y: auto; }
      .nav-section { padding: 16px 20px 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: #4f5457; }
      .sidebar-nav a {
        display: flex; align-items: center; gap: 9px;
        padding: 7px 20px; color: #a7aaad; text-decoration: none; font-size: 13px;
        border-left: 3px solid transparent;
        transition: background 0.1s, color 0.1s;
      }
      .sidebar-nav a:hover { color: #fff; background: #2c3338; }
      .sidebar-nav a.active { color: #fff; background: #2c3338; border-left-color: #2271b1; }
      .sidebar-nav a svg { flex-shrink: 0; opacity: 0.75; }
      .sidebar-nav a:hover svg, .sidebar-nav a.active svg { opacity: 1; }
      .sidebar-footer {
        padding: 12px 20px; border-top: 1px solid #2c3338; font-size: 12px; color: #646970;
      }
      .sidebar-footer-user { display: flex; align-items: center; gap: 7px; margin-bottom: 6px; }
      .sidebar-footer-user svg { opacity: 0.6; flex-shrink: 0; }
      .sidebar-footer strong { color: #a7aaad; font-size: 12px; }
      .sidebar-footer-logout {
        display: flex; align-items: center; gap: 6px; color: #646970; font-size: 11px; cursor: pointer;
        background: none; border: none; padding: 0; font-family: inherit;
      }
      .sidebar-footer-logout:hover { color: #a7aaad; }
      .sidebar-footer-logout svg { opacity: 0.6; }
      .sidebar-footer-logout:hover svg { opacity: 0.9; }

      /* Main */
      .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
      .topbar {
        background: #fff; border-bottom: 1px solid #dcdcde; padding: 0 24px; height: 46px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .topbar-title { font-size: 13px; color: #646970; font-weight: 500; }
      .topbar-user { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #646970; }
      .topbar-user svg { opacity: 0.5; }
      .content { flex: 1; padding: 28px 32px; }
      .page-title { font-size: 22px; font-weight: 600; margin: 0 0 24px; }

      /* Gutenberg editor container */
      .gutenberg-editor { min-height: 400px; }
      .gutenberg-editor .block-editor-writing-flow { outline: none; }
      .gutenberg-editor .block-editor-block-list__layout { padding: 28px; }
    </style>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-brand">
          <Fragment set:html={icons.bolt} />
          AstroPress
        </div>
        <nav class="sidebar-nav">

          <a href="/admin/dashboard" class={currentPath === "/admin/dashboard" ? "active" : ""}>
            <Fragment set:html={icons.dashboard} /> Dashboard
          </a>

          <div class="nav-section">Content</div>
          {postTypes.map((pt) => {
            const href = pt.slug === "post" ? "/admin/posts" : `/admin/cpt/${pt.slug}`;
            const active = pt.slug === "post"
              ? currentPath.startsWith("/admin/posts")
              : currentPath.startsWith(`/admin/cpt/${pt.slug}`);
            const icon = pt.slug === "post" ? icons.post : pt.slug === "page" ? icons.page : icons.folder;
            return (
              <a href={href} class={active ? "active" : ""}>
                <Fragment set:html={icon} />
                {pt.config.pluralLabel}
              </a>
            );
          })}

          <div class="nav-section">Forms</div>
          <a href="/admin/forms" class={currentPath.startsWith("/admin/forms") ? "active" : ""}>
            <Fragment set:html={icons.forms} /> Forms
          </a>

          <div class="nav-section">Structure</div>
          <a href="/admin/custom-fields" class={currentPath.startsWith("/admin/custom-fields") ? "active" : ""}>
            <Fragment set:html={icons.fields} /> Custom Fields
          </a>
          <a href="/admin/post-types" class={currentPath.startsWith("/admin/post-types") ? "active" : ""}>
            <Fragment set:html={icons.posttypes} /> Post Types
          </a>
          <a href="/admin/taxonomies" class={currentPath.startsWith("/admin/taxonomies") ? "active" : ""}>
            <Fragment set:html={icons.taxonomies} /> Taxonomies
          </a>

          <div class="nav-section">Site</div>
          <a href="/admin/plugins" class={currentPath.startsWith("/admin/plugins") ? "active" : ""}>
            <Fragment set:html={icons.plugins} /> Plugins
          </a>
          <a href="/admin/menus" class={currentPath.startsWith("/admin/menus") ? "active" : ""}>
            <Fragment set:html={icons.menus} /> Menus
          </a>
          <a href="/admin/settings" class={currentPath === "/admin/settings" ? "active" : ""}>
            <Fragment set:html={icons.settings} /> Settings
          </a>

        </nav>
        {user && (
          <div class="sidebar-footer">
            <div class="sidebar-footer-user">
              <Fragment set:html={icons.user} />
              <strong>{user.displayName}</strong>
            </div>
            <form method="POST" action="/api/auth/logout" style="margin:0">
              <button type="submit" class="sidebar-footer-logout">
                <Fragment set:html={icons.logout} />
                Log out
              </button>
            </form>
          </div>
        )}
      </aside>

      <div class="main">
        <div class="topbar">
          <span class="topbar-title">{title}</span>
          {user && (
            <span class="topbar-user">
              <Fragment set:html={icons.user} />
              {user.userLogin}
            </span>
          )}
        </div>
        <div class="content">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>
