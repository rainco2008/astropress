---
import { getPostTypes } from "@astropress/core/registry";
import { adminIcons } from "../lib/icons";

interface Props {
  title?: string;
  activeSlug?: string;
}

const { title = "AstroPress Admin", activeSlug } = Astro.props;
const user = Astro.locals.user;
const currentPath = new URL(Astro.request.url).pathname;

const postTypes = getPostTypes().filter((pt) => pt.config.showInMenu);

const icons = adminIcons;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; font-family: system-ui, -apple-system, sans-serif; background: #f6f7f7; color: #1d2327; }
      .layout { display: flex; min-height: 100vh; }

      /* Sidebar */
      .sidebar { width: 220px; background: #1d2327; color: #a7aaad; flex-shrink: 0; display: flex; flex-direction: column; }
      .sidebar-brand {
        padding: 14px 20px; font-size: 15px; font-weight: 700; color: #fff;
        border-bottom: 1px solid #2c3338; letter-spacing: -0.2px;
        display: flex; align-items: center; gap: 8px;
      }
      .sidebar-brand svg { opacity: 0.9; flex-shrink: 0; }
      .sidebar-nav { padding: 8px 0; flex: 1; overflow-y: auto; }
      .nav-section { padding: 16px 20px 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: #4f5457; }
      .sidebar-nav a {
        display: flex; align-items: center; gap: 9px;
        padding: 7px 20px; color: #a7aaad; text-decoration: none; font-size: 13px;
        border-left: 3px solid transparent;
        transition: background 0.1s, color 0.1s;
      }
      .sidebar-nav a:hover { color: #fff; background: #2c3338; }
      .sidebar-nav a.active { color: #fff; background: #2c3338; border-left-color: #2271b1; }
      .sidebar-nav a svg { flex-shrink: 0; opacity: 0.75; }
      .sidebar-nav a:hover svg, .sidebar-nav a.active svg { opacity: 1; }
      .sidebar-footer {
        padding: 12px 20px; border-top: 1px solid #2c3338; font-size: 12px; color: #646970;
      }
      .sidebar-footer-user { display: flex; align-items: center; gap: 7px; margin-bottom: 6px; }
      .sidebar-footer-user svg { opacity: 0.6; flex-shrink: 0; }
      .sidebar-footer strong { color: #a7aaad; font-size: 12px; }
      .sidebar-footer-logout {
        display: flex; align-items: center; gap: 6px; color: #646970; font-size: 11px; cursor: pointer;
        background: none; border: none; padding: 0; font-family: inherit;
      }
      .sidebar-footer-logout:hover { color: #a7aaad; }
      .sidebar-footer-logout svg { opacity: 0.6; }
      .sidebar-footer-logout:hover svg { opacity: 0.9; }

      /* Main */
      .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
      .topbar {
        background: #fff; border-bottom: 1px solid #dcdcde; padding: 0 24px; height: 46px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .topbar-title { font-size: 13px; color: #646970; font-weight: 500; }
      .topbar-user { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #646970; }
      .topbar-user svg { opacity: 0.5; }
      .content { flex: 1; padding: 28px 32px; }
      .page-title { font-size: 22px; font-weight: 600; margin: 0 0 24px; }

      /* Gutenberg editor container */
      .gutenberg-editor { min-height: 400px; }
      .gutenberg-editor .block-editor-writing-flow { outline: none; }
      .gutenberg-editor .block-editor-block-list__layout { padding: 28px; }
    </style>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-brand">
          <Fragment set:html={icons.bolt} />
          AstroPress
        </div>
        <nav class="sidebar-nav">

          <a href="/admin/dashboard" class={currentPath === "/admin/dashboard" ? "active" : ""}>
            <Fragment set:html={icons.dashboard} /> Dashboard
          </a>

          <div class="nav-section">Content</div>
          {postTypes.map((pt) => {
            const href = pt.slug === "post" ? "/admin/posts" : `/admin/cpt/${pt.slug}`;
            const active = pt.slug === "post"
              ? currentPath.startsWith("/admin/posts")
              : currentPath.startsWith(`/admin/cpt/${pt.slug}`);
            const icon = pt.slug === "post" ? icons.post : pt.slug === "page" ? icons.page : icons.folder;
            return (
              <a href={href} class={active ? "active" : ""}>
                <Fragment set:html={icon} />
                {pt.config.pluralLabel}
              </a>
            );
          })}

          <div class="nav-section">Forms</div>
          <a href="/admin/forms" class={currentPath.startsWith("/admin/forms") ? "active" : ""}>
            <Fragment set:html={icons.forms} /> Forms
          </a>

          <div class="nav-section">Structure</div>
          <a href="/admin/custom-fields" class={currentPath.startsWith("/admin/custom-fields") ? "active" : ""}>
            <Fragment set:html={icons.fields} /> Custom Fields
          </a>
          <a href="/admin/post-types" class={currentPath.startsWith("/admin/post-types") ? "active" : ""}>
            <Fragment set:html={icons.posttypes} /> Post Types
          </a>
          <a href="/admin/taxonomies" class={currentPath.startsWith("/admin/taxonomies") ? "active" : ""}>
            <Fragment set:html={icons.taxonomies} /> Taxonomies
          </a>

          <div class="nav-section">Site</div>
          <a href="/admin/plugins" class={currentPath.startsWith("/admin/plugins") ? "active" : ""}>
            <Fragment set:html={icons.plugins} /> Plugins
          </a>
          <a href="/admin/menus" class={currentPath.startsWith("/admin/menus") ? "active" : ""}>
            <Fragment set:html={icons.menus} /> Menus
          </a>
          <a href="/admin/settings" class={currentPath === "/admin/settings" ? "active" : ""}>
            <Fragment set:html={icons.settings} /> Settings
          </a>

        </nav>
        {user && (
          <div class="sidebar-footer">
            <div class="sidebar-footer-user">
              <Fragment set:html={icons.user} />
              <strong>{user.displayName}</strong>
            </div>
            <form method="POST" action="/api/auth/logout" style="margin:0">
              <button type="submit" class="sidebar-footer-logout">
                <Fragment set:html={icons.logout} />
                Log out
              </button>
            </form>
          </div>
        )}
      </aside>

      <div class="main">
        <div class="topbar">
          <span class="topbar-title">{title}</span>
          {user && (
            <span class="topbar-user">
              <Fragment set:html={icons.user} />
              {user.userLogin}
            </span>
          )}
        </div>
        <div class="content">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>
