---
import { adminIcons } from "../lib/icons";
import AIWidget from "../islands/AIWidget";
import { wpOptions } from "@astropress/core/schema";
import { eq } from "drizzle-orm";

interface Props {
  title?: string;
  activeSlug?: string;
  pageContext?: Record<string, any>;
}

const { title = "AstroPress Admin", pageContext = {} } = Astro.props;
const user = Astro.locals.user;
const db = Astro.locals.db;
const currentPath = new URL(Astro.request.url).pathname;

// Load custom post types directly from DB — avoids registry state issues
interface CPTEntry { key: string; label?: string; pluralLabel?: string; showInMenu?: boolean; icon?: string; config?: { label?: string; pluralLabel?: string; showInMenu?: boolean; icon?: string } }
let customPostTypes: CPTEntry[] = [];
if (db) {
  try {
    const [row] = await db.select({ value: wpOptions.optionValue }).from(wpOptions).where(eq(wpOptions.optionName, "astropress_custom_post_types")).limit(1);
    if (row?.value) customPostTypes = JSON.parse(row.value) as CPTEntry[];
  } catch {}
}
// Normalise: support both flat { key, pluralLabel, showInMenu } and nested { key, config: { pluralLabel, showInMenu } }
const customMenuTypes = customPostTypes
  .map((t) => ({ key: t.key, pluralLabel: t.config?.pluralLabel ?? t.pluralLabel ?? t.key, showInMenu: t.config?.showInMenu ?? t.showInMenu }))
  .filter((t) => t.showInMenu !== false);

const icons = adminIcons;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — AstroPress</title>
    <style is:global>
      /* ─── WordPress Design System tokens ──────────────────────────────── */
      :root {
        --wp-blue:            #2271b1;
        --wp-blue-hover:      #135e96;
        --wp-blue-medium:     #0a4b78;
        --wp-blue-light:      #e8f0fb;
        --wp-red:             #d63638;
        --wp-red-hover:       #b32d2e;
        --wp-green:           #00a32a;
        --wp-orange:          #dba617;
        --wp-body-bg:         #f0f0f1;
        --wp-white:           #ffffff;
        --wp-gray-900:        #1d2327;
        --wp-gray-800:        #2c3338;
        --wp-gray-700:        #3c434a;
        --wp-gray-600:        #50575e;
        --wp-gray-500:        #646970;
        --wp-gray-400:        #8c8f94;
        --wp-gray-300:        #c3c4c7;
        --wp-gray-200:        #dcdcde;
        --wp-gray-100:        #f0f0f1;
        --wp-gray-50:         #f6f7f7;
        --wp-sidebar-bg:      #1d2327;
        --wp-sidebar-width:   160px;
        --wp-sidebar-text:    #a7aaad;
        --wp-sidebar-active:  #72aee6;
        --wp-sidebar-hover:   #2c3338;
        --wp-bar-height:      32px;
        --wp-font:            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                              Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
        --wp-radius:          3px;
      }

      /* ─── Reset ───────────────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--wp-font);
        font-size: 13px;
        line-height: 1.4;
        background: var(--wp-body-bg);
        color: var(--wp-gray-900);
      }

      /* ─── Admin bar ───────────────────────────────────────────────────── */
      .wp-admin-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 99999;
        height: var(--wp-bar-height);
        background: var(--wp-gray-900);
        display: flex; align-items: center;
        padding: 0 12px; gap: 16px;
      }
      .wp-admin-bar-brand {
        display: flex; align-items: center; gap: 7px;
        color: #eee; font-size: 13px; font-weight: 600;
        text-decoration: none;
      }
      .wp-admin-bar-brand svg { opacity: 0.85; flex-shrink: 0; }
      .wp-admin-bar-spacer { flex: 1; }
      .wp-admin-bar-user {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; color: var(--wp-gray-400);
      }
      .wp-admin-bar-user svg { opacity: 0.5; }
      .wp-admin-bar-user strong { color: var(--wp-gray-300); font-weight: 500; }

      /* ─── Layout ──────────────────────────────────────────────────────── */
      .wp-layout {
        display: flex;
        padding-top: var(--wp-bar-height);
        min-height: 100vh;
      }

      /* ─── Sidebar ─────────────────────────────────────────────────────── */
      .wp-sidebar {
        width: var(--wp-sidebar-width);
        background: var(--wp-sidebar-bg);
        color: var(--wp-sidebar-text);
        flex-shrink: 0;
        display: flex; flex-direction: column;
        position: fixed;
        top: var(--wp-bar-height); bottom: 0; left: 0;
        overflow-y: auto; z-index: 9999;
      }
      .wp-sidebar-nav { padding: 4px 0; flex: 1; }
      .wp-sidebar-sep { height: 1px; background: rgba(255,255,255,.07); margin: 6px 0; }
      .wp-sidebar-section {
        padding: 16px 14px 4px;
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.6px;
        color: #4f5457;
      }
      .wp-sidebar-nav a {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 14px;
        color: var(--wp-sidebar-text);
        text-decoration: none; font-size: 13px;
        transition: background 0.08s;
      }
      .wp-sidebar-nav a:hover { color: #fff; background: var(--wp-sidebar-hover); }
      .wp-sidebar-nav a.is-active {
        color: var(--wp-sidebar-active);
        background: rgba(255,255,255,.04);
        box-shadow: inset 4px 0 0 var(--wp-sidebar-active);
      }
      .wp-sidebar-nav a svg { flex-shrink: 0; opacity: 0.7; }
      .wp-sidebar-nav a:hover svg,
      .wp-sidebar-nav a.is-active svg { opacity: 1; }

      /* ─── Sidebar sub-menu ────────────────────────────────────────────── */
      .wp-sidebar-submenu { display: none; background: #161b1e; }
      .wp-sidebar-submenu.is-open { display: block; }
      .wp-sidebar-submenu a {
        padding: 5px 14px 5px 30px;
        font-size: 12px; color: #9ea3a8;
      }
      .wp-sidebar-submenu a:hover { color: #fff; background: #0d1115; }
      .wp-sidebar-submenu a.is-active { color: var(--wp-sidebar-active); background: transparent; box-shadow: none; }
      .wp-sidebar-submenu a.is-active::before { content: "›"; margin-right: 4px; }
      .wp-sidebar-footer {
        padding: 10px 14px 14px;
        border-top: 1px solid rgba(255,255,255,.07);
        font-size: 11px; color: var(--wp-gray-500);
      }
      .wp-sidebar-footer-user {
        display: flex; align-items: center; gap: 6px;
        margin-bottom: 6px; color: var(--wp-gray-400);
      }
      .wp-sidebar-footer-user svg { opacity: 0.55; }
      .wp-sidebar-footer strong { font-size: 12px; color: var(--wp-gray-300); }
      .wp-sidebar-footer-logout {
        display: flex; align-items: center; gap: 6px;
        color: var(--wp-gray-500); font-size: 11px;
        background: none; border: none; padding: 3px 0;
        font-family: inherit; cursor: pointer; width: 100%; text-align: left;
      }
      .wp-sidebar-footer-logout:hover { color: var(--wp-gray-300); }
      .wp-sidebar-footer-logout svg { opacity: 0.55; }

      /* ─── Main content ────────────────────────────────────────────────── */
      .wp-main { flex: 1; margin-left: var(--wp-sidebar-width); min-width: 0; display: flex; flex-direction: column; }
      .wp-content { flex: 1; padding: 20px 20px 40px; }

      /* ─── Page heading ────────────────────────────────────────────────── */
      .wp-heading { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin: 0 0 16px; }
      .wp-heading h1 { font-size: 23px; font-weight: 400; line-height: 1.3; margin: 0; padding: 9px 0 4px; color: var(--wp-gray-900); }
      .wp-page-title { font-size: 23px; font-weight: 400; line-height: 1.3; margin: 0 0 16px; padding: 9px 0 4px; color: var(--wp-gray-900); }

      /* ─── Buttons ─────────────────────────────────────────────────────── */
      .button, .button-primary, .button-secondary {
        display: inline-flex; align-items: center; gap: 5px;
        height: 30px; padding: 0 12px;
        font-family: var(--wp-font); font-size: 13px; font-weight: 400;
        line-height: 28px; border-radius: var(--wp-radius);
        cursor: pointer; text-decoration: none; white-space: nowrap;
        transition: border-color .05s, background .05s;
      }
      .button, .button-secondary {
        background: var(--wp-gray-50); border: 1px solid var(--wp-blue); color: var(--wp-blue);
      }
      .button:hover, .button-secondary:hover { background: var(--wp-blue); color: #fff; border-color: var(--wp-blue-hover); }
      .button-primary { background: var(--wp-blue); border: 1px solid var(--wp-blue-hover); color: #fff; font-weight: 600; }
      .button-primary:hover { background: var(--wp-blue-hover); border-color: var(--wp-blue-medium); color: #fff; }
      .button-link { background: none; border: none; padding: 0; height: auto; line-height: inherit; color: var(--wp-blue); text-decoration: underline; cursor: pointer; font-family: inherit; font-size: inherit; }
      .button-link:hover { color: var(--wp-blue-hover); }
      .button-link-delete { background: none; border: none; padding: 0; height: auto; line-height: inherit; color: var(--wp-red); text-decoration: underline; cursor: pointer; font-family: inherit; font-size: inherit; }
      .button-link-delete:hover { color: var(--wp-red-hover); }
      .button-small { height: 24px; padding: 0 8px; font-size: 11px; line-height: 22px; }

      /* ─── Postbox ─────────────────────────────────────────────────────── */
      .postbox { background: var(--wp-white); border: 1px solid var(--wp-gray-300); margin-bottom: 20px; }
      .postbox-header { padding: 8px 12px; border-bottom: 1px solid var(--wp-gray-200); display: flex; align-items: center; justify-content: space-between; }
      .postbox-title { font-size: 14px; font-weight: 600; margin: 0; color: var(--wp-gray-900); }
      .postbox-inside { padding: 12px; }

      /* ─── WP list table ───────────────────────────────────────────────── */
      .wp-list-table { width: 100%; border-collapse: collapse; font-size: 13px; background: var(--wp-white); border: 1px solid var(--wp-gray-300); }
      .wp-list-table thead th { text-align: left; padding: 8px 10px; background: var(--wp-gray-50); border-bottom: 1px solid var(--wp-gray-300); font-weight: 600; color: var(--wp-gray-900); font-size: 13px; }
      .wp-list-table tbody tr { border-bottom: 1px solid var(--wp-gray-200); }
      .wp-list-table tbody tr:last-child { border-bottom: none; }
      .wp-list-table tbody tr:nth-child(odd) { background: var(--wp-gray-50); }
      .wp-list-table tbody tr:nth-child(even) { background: var(--wp-white); }
      .wp-list-table tbody tr:hover { background: #f0f6fc; }
      .wp-list-table td { padding: 9px 10px; vertical-align: top; }
      .wp-list-table .column-title { font-weight: 600; }
      .wp-list-table .row-actions { font-size: 11px; color: var(--wp-gray-500); margin-top: 3px; visibility: hidden; }
      .wp-list-table tbody tr:hover .row-actions { visibility: visible; }
      .wp-list-table .row-actions a { color: var(--wp-gray-500); text-decoration: none; }
      .wp-list-table .row-actions a:hover { color: var(--wp-blue); }
      .wp-list-table .row-actions .delete a:hover { color: var(--wp-red); }
      .wp-list-table .row-actions span { margin-right: 4px; padding-right: 4px; border-right: 1px solid var(--wp-gray-300); }
      .wp-list-table .row-actions span:last-child { border-right: none; }

      /* ─── Status badges ───────────────────────────────────────────────── */
      .status-badge { display: inline-block; font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 10px; text-transform: uppercase; letter-spacing: 0.3px; }
      .status-publish { background: #d1e7dd; color: #146c43; }
      .status-draft   { background: #fff3cd; color: #856404; }
      .status-private { background: #e2e3e5; color: #41464b; }
      .status-trash   { background: #f8d7da; color: #842029; }

      /* ─── Sub-tabs ────────────────────────────────────────────────────── */
      .subsubsub { display: flex; gap: 0; margin: 0 0 12px; padding: 0; list-style: none; font-size: 13px; flex-wrap: wrap; }
      .subsubsub li + li::before { content: "|"; margin: 0 6px; color: var(--wp-gray-400); }
      .subsubsub a { color: var(--wp-blue); text-decoration: none; }
      .subsubsub a:hover { text-decoration: underline; }
      .subsubsub .current { color: var(--wp-gray-900); font-weight: 600; }

      /* ─── Page heading ───────────────────────────────────────────────── */
      .wp-heading-inline { display: inline-block; margin: 0 5px 0 0; font-size: 23px; font-weight: 400; line-height: 1.3; color: var(--wp-gray-900); }
      .page-title-action { display: inline-block; padding: 4px 10px; border: 1px solid var(--wp-gray-400); border-radius: 2px; font-size: 13px; color: var(--wp-gray-700); text-decoration: none; background: var(--wp-white); cursor: pointer; font-family: inherit; font-weight: normal; line-height: 1.6; }
      .page-title-action:hover { background: var(--wp-gray-100); border-color: var(--wp-gray-700); color: var(--wp-gray-900); }
      hr.wp-header-end { border: none; border-top: 1px solid var(--wp-gray-200); margin: 8px 0 16px; }

      /* ─── Tablenav / pagination ───────────────────────────────────────── */
      .tablenav { display: flex; align-items: center; justify-content: flex-end; margin: 8px 0; }
      .tablenav-pages { display: flex; gap: 4px; }

      /* ─── Empty state ─────────────────────────────────────────────────── */
      .ap-empty-state { background: var(--wp-white); border: 1px solid var(--wp-gray-300); padding: 48px 32px; text-align: center; display: flex; flex-direction: column; align-items: center; max-width: 480px; margin-top: 20px; }

      /* ─── Row delete button ───────────────────────────────────────────── */
      .ap-row-delete-btn { background: none; border: none; padding: 0; color: #d63638; cursor: pointer; font-size: 13px; font-family: inherit; }
      .ap-row-delete-btn:hover { color: #a02222; text-decoration: underline; }

      /* ─── Notice ──────────────────────────────────────────────────────── */
      .notice { background: var(--wp-white); border: 1px solid var(--wp-gray-300); border-left: 4px solid var(--wp-blue); padding: 10px 14px; margin-bottom: 16px; font-size: 13px; }
      .notice-success { border-left-color: var(--wp-green); }
      .notice-warning { border-left-color: var(--wp-orange); }
      .notice-error   { border-left-color: var(--wp-red); }

      /* ─── Form controls ───────────────────────────────────────────────── */
      .wp-form-label { display: block; margin-bottom: 4px; font-size: 13px; font-weight: 600; }
      .wp-input, .wp-select, .wp-textarea {
        font-family: var(--wp-font); font-size: 14px; color: var(--wp-gray-900);
        border: 1px solid var(--wp-gray-400); border-radius: var(--wp-radius);
        background: var(--wp-white); outline: none;
        transition: border-color .08s, box-shadow .08s;
      }
      .wp-input, .wp-select { height: 30px; line-height: 28px; padding: 0 8px; }
      .wp-textarea { padding: 6px 8px; resize: vertical; }
      .wp-input:focus, .wp-select:focus, .wp-textarea:focus { border-color: var(--wp-blue); box-shadow: 0 0 0 1px var(--wp-blue); }

      /* ─── Post title input ────────────────────────────────────────────── */
      .wp-post-title-input {
        width: 100%; font-size: 26px; font-weight: 400; line-height: 1.4;
        font-family: var(--wp-font); color: var(--wp-gray-900);
        background: transparent; border: none; border-bottom: 1px solid var(--wp-gray-200);
        padding: 6px 0; margin-bottom: 16px; outline: none; display: block;
      }
      .wp-post-title-input:focus { border-bottom-color: var(--wp-blue); }
      .wp-post-title-input::placeholder { color: var(--wp-gray-300); }

      /* ─── Dashboard stats ─────────────────────────────────────────────── */
      .wp-dashboard-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1px; background: var(--wp-gray-300); border: 1px solid var(--wp-gray-300); margin-bottom: 20px; }
      .wp-stat-box { background: var(--wp-white); padding: 16px; text-decoration: none; color: inherit; display: flex; flex-direction: column; }
      .wp-stat-box:hover { background: #f0f6fc; }
      .wp-stat-num { font-size: 28px; font-weight: 400; line-height: 1.2; color: var(--wp-gray-900); }
      .wp-stat-label { font-size: 14px; color: var(--wp-blue); margin-top: 2px; }

      /* ─── WP nav tabs (Settings sub-pages) ───────────────────────────── */
      .nav-tab-wrapper {
        border-bottom: 1px solid var(--wp-gray-300);
        margin: 0 0 20px;
        padding-top: 9px;
        padding-bottom: 0;
        overflow: hidden;
      }
      .nav-tab {
        float: left;
        border: 1px solid var(--wp-gray-300);
        border-bottom: none;
        margin: 0 4px -1px 0;
        padding: 5px 12px;
        font-size: 13px; font-weight: 500;
        line-height: 1.6;
        background: #e5e5e5;
        color: var(--wp-gray-600);
        text-decoration: none;
        border-radius: 3px 3px 0 0;
        white-space: nowrap;
        transition: background .08s, color .08s;
      }
      .nav-tab:hover { background: var(--wp-body-bg); color: var(--wp-gray-900); }
      .nav-tab-active {
        background: var(--wp-body-bg);
        color: var(--wp-gray-900);
        border-bottom-color: var(--wp-body-bg);
        font-weight: 600;
      }

      /* ─── Gutenberg editor ────────────────────────────────────────────── */
      .gutenberg-editor { min-height: 400px; }
      .gutenberg-editor .block-editor-writing-flow { outline: none; }
      .gutenberg-editor .block-editor-block-list__layout { padding: 28px; }
    </style>
  </head>
  <body>

    <!-- Admin bar -->
    <div class="wp-admin-bar">
      <a class="wp-admin-bar-brand" href="/admin/dashboard">
        <Fragment set:html={icons.bolt} />
        AstroPress
      </a>
      <div class="wp-admin-bar-spacer"></div>
      {user && (
        <div class="wp-admin-bar-user">
          <Fragment set:html={icons.user} />
          <strong>Howdy, {user.displayName}</strong>
        </div>
      )}
    </div>

    <div class="wp-layout">

      <!-- Sidebar -->
      <aside class="wp-sidebar">
        <nav class="wp-sidebar-nav">

          <a href="/admin/dashboard" class={currentPath === "/admin/dashboard" ? "is-active" : ""}>
            <Fragment set:html={icons.dashboard} /> Dashboard
          </a>

          <div class="wp-sidebar-sep"></div>
          <div class="wp-sidebar-section">Content</div>
          <a href="/admin/posts" class={currentPath.startsWith("/admin/posts") ? "is-active" : ""}>
            <Fragment set:html={icons.post} /> Posts
          </a>
          <a href="/admin/pages" class={currentPath.startsWith("/admin/pages") ? "is-active" : ""}>
            <Fragment set:html={icons.page} /> Pages
          </a>
          {customMenuTypes.map((pt) => (
            <a href={`/admin/cpt/${pt.key}`} class={currentPath.startsWith(`/admin/cpt/${pt.key}`) ? "is-active" : ""}>
              <Fragment set:html={icons.folder} />
              {pt.pluralLabel}
            </a>
          ))}
          <a href="/admin/forms" class={currentPath.startsWith("/admin/forms") ? "is-active" : ""}>
            <Fragment set:html={icons.forms} /> Forms
          </a>

          <div class="wp-sidebar-sep"></div>
          <div class="wp-sidebar-section">Structure</div>
          <a href="/admin/post-types" class={currentPath.startsWith("/admin/post-types") ? "is-active" : ""}>
            <Fragment set:html={icons.posttypes} /> Post Types
          </a>
          <a href="/admin/taxonomies" class={currentPath.startsWith("/admin/taxonomies") ? "is-active" : ""}>
            <Fragment set:html={icons.taxonomies} /> Taxonomies
          </a>
          <a href="/admin/custom-fields" class={currentPath.startsWith("/admin/custom-fields") ? "is-active" : ""}>
            <Fragment set:html={icons.fields} /> Custom Fields
          </a>

          <div class="wp-sidebar-sep"></div>
          <div class="wp-sidebar-section">Site</div>
          <a href="/admin/users" class={currentPath.startsWith("/admin/users") ? "is-active" : ""}>
            <Fragment set:html={icons.users} /> Users
          </a>
          <a href="/admin/themes" class={currentPath.startsWith("/admin/themes") ? "is-active" : ""}>
            <Fragment set:html={icons.themes} /> Themes
          </a>
          <a href="/admin/plugins" class={currentPath.startsWith("/admin/plugins") ? "is-active" : ""}>
            <Fragment set:html={icons.plugins} /> Plugins
          </a>
          <a href="/admin/menus" class={currentPath.startsWith("/admin/menus") ? "is-active" : ""}>
            <Fragment set:html={icons.menus} /> Menus
          </a>
          <a href="/admin/settings" class={currentPath.startsWith("/admin/settings") ? "is-active" : ""}>
            <Fragment set:html={icons.settings} /> Settings
          </a>
          <div class={`wp-sidebar-submenu${currentPath.startsWith("/admin/settings") ? " is-open" : ""}`}>
            <a href="/admin/settings" class={currentPath === "/admin/settings" || currentPath === "/admin/settings/" ? "is-active" : ""}>General</a>
            <a href="/admin/settings/ai" class={currentPath.startsWith("/admin/settings/ai") ? "is-active" : ""}>AI</a>
          </div>

        </nav>
        {user && (
          <div class="wp-sidebar-footer">
            <div class="wp-sidebar-footer-user">
              <Fragment set:html={icons.user} />
              <strong>{user.displayName}</strong>
            </div>
            <form method="POST" action="/api/auth/logout" style="margin:0">
              <button type="submit" class="wp-sidebar-footer-logout">
                <Fragment set:html={icons.logout} />
                Log out
              </button>
            </form>
          </div>
        )}
      </aside>

      <!-- Main -->
      <div class="wp-main">
        <div class="wp-content">
          <slot />
        </div>
      </div>

    </div>

    <!-- AI Widget (floats globally) -->
    <AIWidget client:only="react" pageContext={pageContext} />

  </body>
</html>
