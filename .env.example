# AstroPress environment variables
# Copy this file to .env and fill in the values.

# Database URL
# SQLite (local dev / Docker / VPS):
DATABASE_URL=file:./data/astropress.db
# PostgreSQL (Neon, Supabase, Railway Postgres addon):
# DATABASE_URL=postgres://user:password@host/astropress

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-use-a-long-random-string-here
